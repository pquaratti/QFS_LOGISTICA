@model Entidades.Inventario.SubcategoriaProducto
@{ string _ControllerName = "InventarioSubcategorias"; }
<div id="modalFormDefault" class="modal fade modalFormABM" tabindex="-1" role="dialog" data-backdrop="static"><div class="modal-dialog modal-dialog-centered" role="document"><div class="modal-content"><div class="modal-header"><h6 class="modal-title">@(Model.subcatpro_id == 0 ? "Alta Subcategoría" : "Modificar Subcategoría")</h6><button type="button" class="close" data-dismiss="modal"><span><i data-feather="x"></i></span></button></div>@using (Html.BeginForm("SaveModal", _ControllerName, FormMethod.Post, new { id = "formABMDefault", @class = "formularioABMModal", refreshDatatable = "true", resetForm = "true", closeForm = "true" })){<div class="modal-body">@Html.HiddenFor(x=>x.IdEncriptado)@Html.HiddenFor(x=>x.subcatpro_id)<label>Rubro</label>@Html.DropDownListFor(x=>x.RubroProducto.rubpro_id, new SelectList(ViewBag.RubrosDDL,"Value","Text",Model.RubroProducto.rubpro_id), new { @class="form-control form-control-sm", required="required" })<label class="mt-2">Categoría</label>@Html.DropDownListFor(x=>x.CategoriaProducto.catpro_id, new SelectList(ViewBag.CategoriasDDL,"Value","Text",Model.CategoriaProducto.catpro_id), new { @class="form-control form-control-sm", required="required" })<label class="mt-2">Subcategoría</label>@Html.TextBoxFor(x=>x.subcatpro_nombre,new {@class="form-control form-control-sm", required="required"})<label class="mt-2">Descripción</label>@Html.TextAreaFor(x=>x.subcatpro_descripcion,new {@class="form-control",rows="3"})</div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button><button type="submit" class="btn btn-success">Guardar</button></div>}</div></div></div>
