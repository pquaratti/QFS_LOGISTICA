@model Entidades.Inventario.Producto
@{ string _ControllerName = "InventarioProductos"; }
<div id="modalFormDefault" class="modal fade modalFormABM" tabindex="-1" role="dialog" data-backdrop="static"><div class="modal-dialog modal-xl modal-dialog-centered" role="document"><div class="modal-content"><div class="modal-header"><h6 class="modal-title">@(Model.pro_id == 0 ? "Alta Producto" : "Modificar Producto")</h6><button type="button" class="close" data-dismiss="modal"><span><i data-feather="x"></i></span></button></div>@using (Html.BeginForm("SaveModal", _ControllerName, FormMethod.Post, new { id = "formABMDefault", @class = "formularioABMModal", refreshDatatable = "true", resetForm = "true", closeForm = "true" })){<div class="modal-body">@Html.HiddenFor(x=>x.IdEncriptado)@Html.HiddenFor(x=>x.pro_id)<div class="row"><div class="col-md-3"><label>Código interno</label>@Html.TextBoxFor(x=>x.pro_codigo_interno,new {@class="form-control form-control-sm",required="required"})</div><div class="col-md-3"><label>Código barras</label>@Html.TextBoxFor(x=>x.pro_codigo_barras,new {@class="form-control form-control-sm"})</div><div class="col-md-3"><label>Rubro</label>@Html.DropDownListFor(x=>x.RubroProducto.rubpro_id,new SelectList(ViewBag.RubrosDDL,"Value","Text",Model.RubroProducto.rubpro_id),new {@class="form-control form-control-sm",required="required"})</div><div class="col-md-3"><label>Categoría</label>@Html.DropDownListFor(x=>x.CategoriaProducto.catpro_id,new SelectList(ViewBag.CategoriasDDL,"Value","Text",Model.CategoriaProducto.catpro_id),new {@class="form-control form-control-sm",required="required"})</div></div><div class="row mt-2"><div class="col-md-3"><label>Subcategoría</label>@Html.DropDownListFor(x=>x.SubcategoriaProducto.subcatpro_id,new SelectList(ViewBag.SubcategoriasDDL,"Value","Text",Model.SubcategoriaProducto.subcatpro_id),new {@class="form-control form-control-sm",required="required"})</div><div class="col-md-3"><label>Unidad</label>@Html.DropDownListFor(x=>x.UnidadMedida.unimed_id,new SelectList(ViewBag.UnidadesDDL,"Value","Text",Model.UnidadMedida.unimed_id),new {@class="form-control form-control-sm",required="required"})</div><div class="col-md-3"><label>Presentación</label>@Html.TextBoxFor(x=>x.pro_presentacion,new {@class="form-control form-control-sm"})</div><div class="col-md-3"><label>Tipo producto</label>@Html.TextBoxFor(x=>x.pro_tipo_producto,new {@class="form-control form-control-sm"})</div></div><div class="row mt-2"><div class="col-md-3"><label>Marca</label>@Html.TextBoxFor(x=>x.pro_marca,new {@class="form-control form-control-sm"})</div><div class="col-md-3"><label>Modelo</label>@Html.TextBoxFor(x=>x.pro_modelo,new {@class="form-control form-control-sm"})</div><div class="col-md-2"><label>Stock mínimo</label>@Html.TextBoxFor(x=>x.pro_stock_minimo,new {@class="form-control form-control-sm", type="number", step="0.0001"})</div><div class="col-md-2"><label>Stock máximo</label>@Html.TextBoxFor(x=>x.pro_stock_maximo,new {@class="form-control form-control-sm", type="number", step="0.0001"})</div><div class="col-md-2"><label>Punto reposición</label>@Html.TextBoxFor(x=>x.pro_punto_reposicion,new {@class="form-control form-control-sm", type="number", step="0.0001"})</div></div><div class="row mt-3"><div class="col-md-2"><label>@Html.CheckBoxFor(x=>x.pro_requiere_trazabilidad) Trazable</label></div><div class="col-md-2"><label>@Html.CheckBoxFor(x=>x.pro_requiere_lote) Requiere lote</label></div><div class="col-md-2"><label>@Html.CheckBoxFor(x=>x.pro_requiere_vencimiento) Requiere venc.</label></div><div class="col-md-2"><label>@Html.CheckBoxFor(x=>x.pro_requiere_serie) Requiere serie</label></div><div class="col-md-2"><label>@Html.CheckBoxFor(x=>x.pro_activo) Activo</label></div><div class="col-md-2"><label>Estado</label>@Html.TextBoxFor(x=>x.pro_estado,new {@class="form-control form-control-sm"})</div></div><div class="row mt-2"><div class="col-md-6"><label>Descripción corta</label>@Html.TextBoxFor(x=>x.pro_descripcion_corta,new {@class="form-control form-control-sm",required="required"})</div><div class="col-md-6"><label>Descripción larga</label>@Html.TextBoxFor(x=>x.pro_descripcion_larga,new {@class="form-control form-control-sm"})</div></div><div class="row mt-2"><div class="col-md-12"><label>Observaciones</label>@Html.TextAreaFor(x=>x.pro_observaciones,new {@class="form-control",rows="3"})</div></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button><button type="submit" class="btn btn-success">Guardar</button></div>}</div></div></div>
