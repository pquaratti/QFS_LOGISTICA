@model List<Entidades.Inventario.Producto>
@{ string _ControllerName = "InventarioProductos"; }
<table class="table table-sm table-header-app datatablePartial-scrollbar"><thead><tr><th>Código</th><th>Descripción</th><th>Rubro</th><th>Categoría</th><th>Subcategoría</th><th>Unidad</th><th>Estado</th><th></th></tr></thead><tbody>@foreach (var item in Model){<tr><td>@item.pro_codigo_interno</td><td>@item.pro_descripcion_corta</td><td>@item.RubroProducto.rubpro_nombre</td><td>@item.CategoriaProducto.catpro_nombre</td><td>@item.SubcategoriaProducto.subcatpro_nombre</td><td>@item.UnidadMedida.unimed_nombre</td><td>@item.pro_estado</td><td><button type="button" modal-value-primary="@item.IdEncriptado" modal-value-secondary="0" modal-value-aux="0" modal-url="@Url.Action("PartialModalABM",_ControllerName)" class="btn btn-info btn-sm btn-grid btnOpenModal"><i class="fa fa-edit"></i></button><button type="button" data-id-rel="@item.pro_id" url-delete="@Url.Action("Delete",_ControllerName)" class="btn btn-danger btn-sm btn-grid btn-borrar-detalle"><i class="fa fa-trash"></i></button></td></tr>}</tbody></table>
