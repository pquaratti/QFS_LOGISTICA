@model Entidades.Inventario.UnidadMedida
@{ string _ControllerName = "InventarioUnidadesMedidas"; }
<div id="modalFormDefault" class="modal fade modalFormABM" tabindex="-1" role="dialog" data-backdrop="static"><div class="modal-dialog modal-dialog-centered" role="document"><div class="modal-content"><div class="modal-header"><h6 class="modal-title">@(Model.unimed_id == 0 ? "Alta unidad de medida" : "Modificar unidad de medida")</h6><button type="button" class="close" data-dismiss="modal"><span><i data-feather="x"></i></span></button></div>@using (Html.BeginForm("SaveModal", _ControllerName, FormMethod.Post, new { id = "formABMDefault", @class = "formularioABMModal", refreshDatatable = "true", resetForm = "true", closeForm = "true" })){<div class="modal-body">@Html.HiddenFor(x=>x.IdEncriptado)@Html.HiddenFor(x=>x.unimed_id)<label>Nombre</label>@Html.TextBoxFor(x=>x.unimed_nombre,new {@class="form-control form-control-sm", required="required"})<label class="mt-2">Código</label>@Html.TextBoxFor(x=>x.unimed_codigo,new {@class="form-control form-control-sm", required="required"})<div class="custom-control custom-checkbox mt-3">@Html.CheckBoxFor(x=>x.unimed_activo,new {@class="custom-control-input"})<label class="custom-control-label" for="unimed_activo">Activo</label></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button><button type="submit" class="btn btn-success">Guardar</button></div>}</div></div></div>
