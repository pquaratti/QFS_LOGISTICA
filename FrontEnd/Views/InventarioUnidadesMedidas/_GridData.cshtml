@model IEnumerable<Entidades.Inventario.UnidadMedida>
@{ string _ControllerName = "InventarioUnidadesMedidas"; }
<table class="table table-sm table-header-app datatablePartial-scrollbar"><thead><tr><th>Nombre</th><th>Código</th><th></th></tr></thead><tbody>@foreach (var r in Model){<tr><td>@r.unimed_nombre</td><td>@r.unimed_codigo</td><td><button type="button" modal-value-primary="@r.IdEncriptado" modal-value-secondary="0" modal-value-aux="0" modal-url="@Url.Action("PartialModalABM",_ControllerName)" class="btn btn-info btn-sm btn-grid btnOpenModal"><i class="fa fa-edit"></i></button><button type="button" data-id-rel="@r.unimed_id" url-delete="@Url.Action("Delete",_ControllerName)" class="btn btn-danger btn-sm btn-grid btn-borrar-detalle"><i class="fa fa-trash"></i></button></td></tr>}</tbody></table>
