@model Entidades.Inventario.RubroProducto
@{ string _ControllerName = "InventarioRubros"; }
<div id="modalFormDefault" class="modal fade modalFormABM" tabindex="-1" role="dialog" data-backdrop="static"><div class="modal-dialog modal-dialog-centered" role="document"><div class="modal-content"><div class="modal-header"><h6 class="modal-title">@(Model.rubpro_id == 0 ? "Alta Rubro" : "Modificar Rubro")</h6><button type="button" class="close" data-dismiss="modal"><span><i data-feather="x"></i></span></button></div>@using (Html.BeginForm("SaveModal", _ControllerName, FormMethod.Post, new { id = "formABMDefault", @class = "formularioABMModal", refreshDatatable = "true", resetForm = "true", closeForm = "true" })){<div class="modal-body">@Html.HiddenFor(x=>x.IdEncriptado)@Html.HiddenFor(x=>x.rubpro_id)<label>Nombre</label>@Html.TextBoxFor(x=>x.rubpro_nombre,new {@class="form-control form-control-sm", required="required"})<label class="mt-2">Descripción</label>@Html.TextAreaFor(x=>x.rubpro_descripcion,new {@class="form-control",rows="3"})</div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button><button type="submit" class="btn btn-success">Guardar</button></div>}</div></div></div>
