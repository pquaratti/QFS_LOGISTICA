@model FrontEnd.Models.DepositoOcupacionViewModel
@{
    ViewBag.Title = "Inventario depósito";
    var productosDisponiblesJson = Json.Encode(Model.ProductosDisponibles);
    ViewBag.Subtitle = "Grilla de ocupación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .ocupacion-kpi {
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        padding: 14px;
        background: #fff;
        min-height: 92px;
    }

        .ocupacion-kpi span {
            color: #64748b;
            display: block;
            font-size: 12px;
            text-transform: uppercase;
        }

        .ocupacion-kpi strong {
            color: #0f172a;
            display: block;
            font-size: 26px;
            line-height: 32px;
        }

    .zona-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        margin-bottom: 18px;
        overflow: hidden;
        background: #fff;
    }

    .zona-head {
        align-items: center;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        padding: 14px 16px;
    }

    .pasillo-card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        margin: 14px;
        padding: 14px;
    }

    .ubicacion-grid {
        border-collapse: separate;
        border-spacing: 6px;
        min-width: 720px;
    }

        .ubicacion-grid th {
            color: #475569;
            font-size: 11px;
            text-align: center;
        }

    .ubicacion-cell {
        border: 0;
        border-radius: 8px;
        color: #fff;
        cursor: pointer;
        min-width: 92px;
        padding: 8px;
        text-align: center;
        vertical-align: middle;
    }

        .ubicacion-cell small {
            display: block;
            font-size: 10px;
            opacity: .9;
        }

    .ubicacion-libre {
        background: #16a34a;
    }

    .ubicacion-libre-asignada {
        background: #166534;
    }

    .ubicacion-parcial {
        background: #f59e0b;
    }

    .ubicacion-ocupada {
        background: #dc2626;
    }

    .ubicacion-bloqueada {
        background: #64748b;
    }

    .ubicacion-teorica {
        box-shadow: inset 0 0 0 2px rgba(255,255,255,.45);
    }

    .legend-dot {
        border-radius: 50%;
        display: inline-block;
        height: 10px;
        margin-right: 4px;
        width: 10px;
    }
</style>

<div class="content-header header-title-page ml-0 mr-0">
    <div class="col-md-9">
        <h4 class="content-title content-title-xs">Inventario depósito</h4>
        <p>Grilla por zonas, estanterías, posiciones y alturas @(Model.Deposito != null && !string.IsNullOrWhiteSpace(Model.Deposito.depo_nombre) ? "- " + Model.Deposito.depo_nombre : "")</p>
    </div>
    <div class="col-md-3 pr-0">
        <div class="d-flex flex-row-reverse">
            <a class="btn btn-xs btn-secondary m-1" href="@Url.Action("Index", "Depositos")"><i class="fa fa-arrow-left"></i> Volver</a>
        </div>
    </div>
</div>

<div class="alert alert-info">
    Hac click en una posicin real para ver el producto asignado, definir la capacidad mxima de ese producto y cargar unidades sin superar el mximo.
</div>

<div class="row mb-3">
    <div class="col-md-3"><div class="ocupacion-kpi"><span>Lugares totales</span><strong>@Model.TotalLugares</strong></div></div>
    <div class="col-md-3"><div class="ocupacion-kpi"><span>Ocupados</span><strong>@Model.LugaresOcupados</strong></div></div>
    <div class="col-md-3"><div class="ocupacion-kpi"><span>Libres</span><strong>@Model.LugaresLibres</strong></div></div>
    <div class="col-md-3"><div class="ocupacion-kpi"><span>Ocupación</span><strong>@Model.PorcentajeOcupacion%</strong></div></div>
</div>

<div class="card card-body">
    <div class="mb-2">
        <span class="mr-3"><i class="legend-dot ubicacion-libre"></i>Libre sin producto</span>
        <span class="mr-3"><i class="legend-dot ubicacion-libre-asignada"></i>Libre con producto asignado</span>
        <span class="mr-3"><i class="legend-dot ubicacion-parcial"></i>Parcial</span>
        <span class="mr-3"><i class="legend-dot ubicacion-ocupada"></i>Ocupada / reservada</span>
        <span class="mr-3"><i class="legend-dot ubicacion-bloqueada"></i>Bloqueada</span>
    </div>

    @if (Model.Zonas.Count == 0)
    {
    <div class="alert alert-info mb-0">No hay zonas, estanterías o posiciones configuradas para mostrar.</div>
    }

    @foreach (var zona in Model.Zonas)
    {
    <div class="zona-card">
        <div class="zona-head">
            <div>
                <strong>@zona.Codigo - @zona.Nombre</strong><br />
                <small>@zona.TotalLugares lugares · @zona.LugaresOcupados ocupados · @zona.LugaresLibres libres · @zona.PorcentajeOcupacion% ocupado</small>
            </div>
        </div>

        @foreach (var pasillo in zona.Pasillos)
            {
        <div class="pasillo-card">
            <div class="d-flex justify-content-between mb-2">
                <div>
                    <h6 class="mb-0">@pasillo.Codigo - @pasillo.Nombre</h6>
                    <small>@pasillo.Posiciones posiciones · @pasillo.Alturas alturas · altura nivel @pasillo.AlturaNivel · peso máx. @pasillo.PesoMaximo</small>
                </div>
                <strong>@pasillo.PorcentajeOcupacion%</strong>
            </div>
            <div class="table-responsive">
                <table class="ubicacion-grid">
                    <thead>
                        <tr>
                            <th>Nivel</th>
                            @for (int posicion = 1; posicion <= pasillo.Posiciones; posicion++)
                                    {
                            <th>P@(posicion.ToString("000"))</th>
                                    }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int nivel = pasillo.Alturas; nivel >= 1; nivel--)
                                {
                        <tr>
                            <th>N@(nivel.ToString("00"))</th>
                            @for (int posicion = 1; posicion <= pasillo.Posiciones; posicion++)
                            {
                                var ubicacion = pasillo.Ubicaciones.FirstOrDefault(x => x.Posicion == posicion && x.Nivel == nivel.ToString());
                                var tieneProductoAsignado = ubicacion.ProductoID > 0;
                                var claseEstado = ubicacion.EsBloqueada ? "ubicacion-bloqueada" : ubicacion.Estado.IndexOf("parcial", StringComparison.OrdinalIgnoreCase) >= 0 ? "ubicacion-parcial" : ubicacion.EsOcupada ? "ubicacion-ocupada" : tieneProductoAsignado ? "ubicacion-libre-asignada" : "ubicacion-libre";
                                var claseReal = ubicacion.EsUbicacionReal ? "" : "ubicacion-teorica";
                                var cantidadActualTexto = ubicacion.CantidadActual.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                            <td class="ubicacion-cell @claseEstado @claseReal btn-ubicacion-producto"
                                title="@ubicacion.Codigo | @ubicacion.Estado | Producto @ubicacion.ProductoDescripcion | @cantidadActualTexto/@ubicacion.CantidadMaxima"
                                data-id="@ubicacion.Id"
                                data-pasillo-id="@pasillo.Id"
                                data-posicion="@ubicacion.Posicion"
                                data-nivel="@ubicacion.Nivel"
                                data-codigo="@ubicacion.Codigo"
                                data-estado="@ubicacion.Estado"
                                data-producto-id="@ubicacion.ProductoID"
                                data-producto-descripcion="@ubicacion.ProductoDescripcion"
                                data-cantidad="@cantidadActualTexto"
                                data-maximo="@ubicacion.CantidadMaxima"
                                data-real="@ubicacion.EsUbicacionReal.ToString().ToLowerInvariant()">
                                <strong>@ubicacion.PorcentajeOcupacion%</strong>
                                <small>@ubicacion.Codigo</small>
                                <small>@ubicacion.Estado</small>
                                <small>@ubicacion.ProductoDescripcion</small>
                                <small>@cantidadActualTexto/@ubicacion.CantidadMaxima</small>
                            </td>
                                        }
                        </tr>
                                }
                    </tbody>
                </table>
            </div>
        </div>
            }
    </div>
    }
</div>
<div id="modalUbicacionProducto" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Asignar producto a ubicacin</h6>
                <button type="button" class="close" data-dismiss="modal"><span><i data-feather="x"></i></span></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="ubicacionProductoID" />
                <div class="alert alert-secondary py-2">
                    <strong id="ubicacionProductoCodigo"></strong><br />
                    <small id="ubicacionProductoEstado"></small>
                </div>
                <div class="form-group">
                    <label>Producto</label>
                    <select id="productoID" class="form-control form-control-sm"></select>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label>Cantidad actual</label>
                        <input id="cantidadActual" type="number" min="0" step="1" class="form-control form-control-sm" />
                    </div>
                    <div class="form-group col-md-6">
                        <label>Cantidad mxima soportada</label>
                        <input id="cantidadMaxima" type="number" min="1" step="1" class="form-control form-control-sm" />
                    </div>
                </div>
                <div id="ubicacionProductoMensaje" class="alert d-none mb-0"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="button" id="btnGuardarUbicacionProducto" class="btn btn-success">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
    var productosDisponibles = @Html.Raw(productosDisponiblesJson);

    $(document).ready(function () {
        cargarProductosDisponibles();

        $(document).on('click', '.btn-ubicacion-producto', function () {
            abrirModalUbicacionProducto($(this));
        });

        $('#btnGuardarUbicacionProducto').on('click', guardarUbicacionProducto);
    });

    function cargarProductosDisponibles() {
        var $producto = $('#productoID');
        $producto.empty();
        $.each(productosDisponibles, function (_, item) {
            $producto.append($('<option/>').val(item.Value).text(item.Text));
        });
    }

    function abrirModalUbicacionProducto($celda) {
        limpiarMensajeUbicacionProducto();
        $('#btnGuardarUbicacionProducto').prop('disabled', false);
        $('#ubicacionProductoID').val($celda.data('id'));
        $('#ubicacionProductoID').data('pasillo-id', $celda.data('pasillo-id'));
        $('#ubicacionProductoID').data('posicion', $celda.data('posicion'));
        $('#ubicacionProductoID').data('nivel', $celda.data('nivel'));
        $('#ubicacionProductoCodigo').text($celda.data('codigo'));
        $('#ubicacionProductoEstado').text('Estado: ' + $celda.data('estado') + ' | Producto actual: ' + $celda.data('producto-descripcion'));

        var productoActualID = parseInt($celda.data('producto-id'), 10);
        if (productoActualID > 0) {
            $('#productoID').val(productoActualID.toString());
        } else {
            $('#productoID').prop('selectedIndex', 0);
        }

        $('#cantidadActual').val($celda.data('cantidad') || 0);
        $('#cantidadMaxima').val($celda.data('maximo') || '');
        $('#modalUbicacionProducto').modal('show');
    }

    function guardarUbicacionProducto() {
        limpiarMensajeUbicacionProducto();

        var cantidad = parseFloat(($('#cantidadActual').val() || '').replace(',', '.'));
        var cantidadMaxima = parseInt($('#cantidadMaxima').val(), 10);
        var productoID = parseInt($('#productoID').val(), 10);

        if (!productoID || productoID <= 0) { mostrarMensajeUbicacionProducto('danger', 'Seleccion un producto.'); return; }
        if (isNaN(cantidad) || cantidad < 0) { mostrarMensajeUbicacionProducto('danger', 'La cantidad actual no puede ser negativa.'); return; }
        if (isNaN(cantidadMaxima) || cantidadMaxima <= 0) { mostrarMensajeUbicacionProducto('danger', 'La cantidad mxima debe ser mayor a cero.'); return; }
        if (cantidad > cantidadMaxima) { mostrarMensajeUbicacionProducto('danger', 'La cantidad actual no puede superar la cantidad mxima.'); return; }

        $('#btnGuardarUbicacionProducto').prop('disabled', true);
        $.ajax({
            url: '@Url.Action("GuardarProductoUbicacion", "Depositos")',
            type: 'POST',
            data: {
                UbicacionID: $('#ubicacionProductoID').val(),
                PasilloID: $('#ubicacionProductoID').data('pasillo-id'),
                Posicion: $('#ubicacionProductoID').data('posicion'),
                Nivel: $('#ubicacionProductoID').data('nivel'),
                ProductoID: productoID,
                Cantidad: cantidad,
                CantidadMaxima: cantidadMaxima
            },
            success: function (response) {
                if (response.Result && response.Result.Success) {
                    location.reload();
                    return;
                }

                mostrarMensajeUbicacionProducto('danger', response.Result ? response.Result.Message : 'No se pudo guardar la asignacin.');
                $('#btnGuardarUbicacionProducto').prop('disabled', false);
            },
            error: function () {
                mostrarMensajeUbicacionProducto('danger', 'No se pudo guardar la asignacin.');
                $('#btnGuardarUbicacionProducto').prop('disabled', false);
            }
        });
    }

    function mostrarMensajeUbicacionProducto(tipo, mensaje) {
        $('#ubicacionProductoMensaje').removeClass('d-none alert-success alert-danger alert-warning alert-info').addClass('alert-' + tipo).text(mensaje);
    }

    function limpiarMensajeUbicacionProducto() {
        $('#ubicacionProductoMensaje').addClass('d-none').removeClass('alert-success alert-danger alert-warning alert-info').text('');
    }
    </script>
}