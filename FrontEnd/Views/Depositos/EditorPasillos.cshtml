@model Entidades.Deposito

@{
    ViewBag.Title = "Editor de pasillos";
    ViewBag.Subtitle = "Diseńo 2D de depósito";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string _ControllerName = "Depositos";
    var _zonasEditor = ViewBag.EditorZonas ?? new object[0];
}

<style>
    .wms-editor-toolbar .form-control {
        height: 30px;
        padding: 2px 8px;
    }

    .wms-editor-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 15px;
    }

    .wms-editor-canvas-wrap {
        background: #f8fafc;
        border: 1px solid #d8e1ea;
        border-radius: 6px;
        min-height: 620px;
        overflow: auto;
        position: relative;
    }

    #canvasPasillos {
        background-image: linear-gradient(#eef2f7 1px, transparent 1px), linear-gradient(90deg, #eef2f7 1px, transparent 1px);
        background-size: 20px 20px;
        cursor: crosshair;
        touch-action: none;
        user-select: none;
    }

    #canvasPasillos.dragging {
        cursor: grabbing;
    }

    .wms-panel {
        border-left: 4px solid #10b981;
    }

    .wms-help {
        font-size: 12px;
        color: #64748b;
    }

    .wms-pasillo-item {
        cursor: pointer;
    }

        .wms-pasillo-item.active {
            background: #e8fff5;
        }

    @@media (max-width: 992px) {
        .wms-editor-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="content-header header-title-page ml-0 mr-0">
    <div class="col-md-8">
        <h4 class="content-title content-title-xs">Editor 2D de pasillos</h4>
        <p>Depósito: <strong>@Model.depo_nombre</strong> (@Model.depo_codigo)</p>
    </div>
    <div class="col-md-4 pr-0">
        <div class="d-flex flex-row-reverse">
            <a href="@Url.Action("Index", _ControllerName)" class="btn btn-xs btn-secondary m-1"><i class="fa fa-arrow-left"></i> Volver</a>
            <button id="btnNuevaZona" type="button" class="btn btn-xs btn-primary m-1"><i class="fa fa-object-group"></i> Zona</button>
            <button id="btnNuevoPasillo" type="button" class="btn btn-xs btn-success m-1"><i class="fa fa-plus"></i> Pasillo</button>
        </div>
    </div>
</div>

<div class="card card-body">
    <div class="alert alert-info mb-3">
        Creá zonas visuales separadas y luego dibujá o seleccioná un pasillo para configurar posiciones y alturas. Al guardar se generan ubicaciones del tipo <strong>P01-P001-N01</strong>, una por cada posición/nivel.
    </div>

    <div class="wms-editor-layout">
        <div class="wms-editor-canvas-wrap">
            <canvas id="canvasPasillos" width="1200" height="620"></canvas>
        </div>

        <div class="card card-body wms-panel">
            <h6 class="mb-3">Configuración del pasillo</h6>
            <div class="form-group"><label>Zona</label><select id="pasilloZona" class="form-control form-control-sm"></select></div>
            <input type="hidden" id="pasilloID" value="0" />
            <input type="hidden" id="depositoID" value="@Model.depo_id" />

            <div class="row wms-editor-toolbar">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Código</label>
                        <input id="pasilloCodigo" class="form-control form-control-sm" maxlength="30" placeholder="P01" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input id="pasilloNombre" class="form-control form-control-sm" maxlength="100" placeholder="Pasillo 1" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>X</label>
                        <input id="pasilloX" type="number" class="form-control form-control-sm" value="40" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Y</label>
                        <input id="pasilloY" type="number" class="form-control form-control-sm" value="40" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Largo</label>
                        <input id="pasilloLargo" type="number" class="form-control form-control-sm" value="240" min="1" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Ancho</label>
                        <input id="pasilloAncho" type="number" class="form-control form-control-sm" value="60" min="1" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Orientación</label>
                        <select id="pasilloOrientacion" class="form-control form-control-sm">
                            <option value="H">Horizontal</option>
                            <option value="V">Vertical</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Posiciones</label>
                        <input id="pasilloPosiciones" type="number" class="form-control form-control-sm" value="10" min="1" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Alturas</label>
                        <input id="pasilloAlturas" type="number" class="form-control form-control-sm" value="3" min="1" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Altura nivel</label>
                        <input id="pasilloAlturaNivel" type="number" class="form-control form-control-sm" value="100" min="0" />
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <label>Peso máximo</label>
                        <input id="pasilloPesoMaximo" type="number" class="form-control form-control-sm" value="0" min="0" />
                    </div>
                </div>
            </div>

            <div class="btn-group btn-block mb-2" role="group">
                <button id="btnGuardarPasillo" type="button" class="btn btn-success btn-sm"><i class="fa fa-save"></i> Guardar y generar</button>
                <button id="btnEliminarPasillo" type="button" class="btn btn-danger btn-sm"><i class="fa fa-trash"></i> Borrar</button>
            </div>

            <p class="wms-help">Tip: hacé click o arrastrá sobre el plano para posicionar el pasillo. Para mover uno existente, seleccion el pasillo y arrastralo; luego guardá los cambios.</p>

            <hr />
            <h6>Zonas</h6>
            <div id="listaZonas" class="list-group small mb-3"></div>
            <hr />
            <h6>Pasillos creados</h6>
            <div id="listaPasillos" class="list-group small"></div>
        </div>
    </div>
</div>

@section scripts{
    <script>
    var zonas = @Html.Raw(Json.Encode(_zonasEditor));
    var zonaSeleccionada = null;
    var pasillos = [];
    var pasilloSeleccionado = null;
    var canvas = document.getElementById('canvasPasillos');
    var ctx = canvas.getContext('2d');
    var dragPasillo = null;
    var dragOffsetX = 0;
    var dragOffsetY = 0;
    var dragMovido = false;
    var dragActivo = false;

    $(document).ready(function () {
        renderZonas();
        cargarPasillos();
    });

    $('#btnNuevaZona').click(function () {
        var n = zonas.length + 1;
        var data = { 'obj.Deposito.depo_id': $('#depositoID').val(), 'obj.depzon_codigo': 'Z' + String(n).padStart(2, '0'), 'obj.depzon_nombre': 'Zona ' + n, 'obj.depzon_x': n === 1 ? 30 : 640, 'obj.depzon_y': 30, 'obj.depzon_largo': 520, 'obj.depzon_ancho': 540 };
        $.post('@Url.Action("SaveZona", _ControllerName)', data, function (response) { if (response.Result.Success) cargarZonas(); else alert(response.Result.Message || 'No se pudo guardar la zona.'); });
    });

    $('#pasilloZona').change(function () { zonaSeleccionada = zonas.find(function (z) { return String(z.dbId) === String($('#pasilloZona').val()); }) || null; dibujar(); });

    $('#btnNuevoPasillo').click(function () {
        limpiarFormulario();
        $('#pasilloCodigo').val('P' + String(pasillos.length + 1).padStart(2, '0'));
        $('#pasilloNombre').val('Pasillo ' + (pasillos.length + 1));
    });

    $('#canvasPasillos').on('mousedown touchstart', iniciarArrastrePasillo);
    $(document).on('mousemove touchmove', moverPasilloArrastrado);
    $(document).on('mouseup touchend touchcancel', finalizarArrastrePasillo);

    $('#canvasPasillos').click(function (e) {
        if (dragMovido) {
            dragMovido = false;
            return;
        }

        var punto = obtenerPuntoCanvas(e);
        var encontrado = buscarPasilloEnPunto(punto.x, punto.y);

        if (encontrado) {
            seleccionarPasillo(encontrado);
        } else {
            posicionarFormularioEnCanvas(punto.x, punto.y);
            dibujar();
        }
    });

    $('#btnGuardarPasillo').click(function () {
        guardarPasillo();
    });

    $('#btnEliminarPasillo').click(function () {
        if (!pasilloSeleccionado || pasilloSeleccionado.id === '0') {
            alert('Seleccione un pasillo para borrar.');
            return;
        }

        if (!confirm('żDesea borrar el pasillo seleccionado?')) return;

        $.post('@Url.Action("DeletePasillo", _ControllerName)', { BorrarID: pasilloSeleccionado.id }, function (response) {
            if (response.Result.Success) {
                limpiarFormulario();
                cargarPasillos();
            } else {
                alert(response.Result.Message || 'No se pudo borrar el pasillo.');
            }
        });
    });

    $('.wms-editor-toolbar input, .wms-editor-toolbar select').on('input change', function () {
        actualizarPreview();
    });

    function cargarZonas() {
        $.get('@Url.Action("ListarZonas", _ControllerName)', { depositoID: '@Model.IdEncriptado' }, function (response) { zonas = response.Data || []; renderZonas(); dibujar(); });
    }

    function cargarPasillos() {
        $.get('@Url.Action("ListarPasillos", _ControllerName)', { depositoID: '@Model.IdEncriptado' }, function (response) {
            pasillos = response.Data || [];
            renderLista();
            dibujar();
        });
    }

    function guardarPasillo() {
        if (!$('#pasilloCodigo').val()) {
            alert('Ingrese el código del pasillo.');
            return;
        }

        var data = {
            'obj.depopas_id': $('#pasilloID').val() || 0,
            'obj.Deposito.depo_id': $('#depositoID').val(),
            'obj.depopas_codigo': $('#pasilloCodigo').val(),
            'obj.depopas_nombre': $('#pasilloNombre').val(),
            'obj.Zona.depzon_id': $('#pasilloZona').val() || 0,
            'obj.depopas_x': $('#pasilloX').val(),
            'obj.depopas_y': $('#pasilloY').val(),
            'obj.depopas_largo': $('#pasilloLargo').val(),
            'obj.depopas_ancho': $('#pasilloAncho').val(),
            'obj.depopas_orientacion': $('#pasilloOrientacion').val(),
            'obj.depopas_cantidad_posiciones': $('#pasilloPosiciones').val(),
            'obj.depopas_cantidad_alturas': $('#pasilloAlturas').val(),
            'obj.depopas_altura_nivel': $('#pasilloAlturaNivel').val(),
            'obj.depopas_peso_maximo': $('#pasilloPesoMaximo').val(),
            generarUbicaciones: true
        };

        $.post('@Url.Action("SavePasillo", _ControllerName)', data, function (response) {
            if (response.Result.Success) {
                cargarPasillos();
                alert(response.Result.Message || 'Pasillo guardado.');
            } else {
                alert(response.Result.Message || 'No se pudo guardar el pasillo.');
            }
        });
    }

    function renderZonas() {
        var options = '<option value="0">Seleccione zona</option>';
        var html = '';
        zonas.forEach(function (z) {
            options += '<option value="' + z.dbId + '">' + z.codigo + ' - ' + z.nombre + '</option>';
            html += '<button type="button" class="list-group-item list-group-item-action wms-zona-item" data-id="' + z.dbId + '"><strong>' + z.codigo + '</strong> - ' + z.nombre + '</button>';
        });
        $('#pasilloZona').html(options);
        $('#listaZonas').html(html || '<div class="text-muted">Todava no hay zonas. Us + Zona para crear dos reas separadas.</div>');
        $('.wms-zona-item').click(function () { var zonaId = $(this).data('id'); zonaSeleccionada = zonas.find(function (z) { return String(z.dbId) === String(zonaId); }); if (zonaSeleccionada) $('#pasilloZona').val(zonaSeleccionada.dbId); dibujar(); });
    }

    function renderLista() {
        var html = '';
        pasillos.forEach(function (p) {
            html += '<button type="button" class="list-group-item list-group-item-action wms-pasillo-item" data-id="' + p.id + '">' +
                '<strong>' + p.codigo + '</strong> - ' + p.nombre + '<br />' +
                '<span class="text-muted">' + p.posiciones + ' posiciones x ' + p.alturas + ' alturas</span>' +
                '</button>';
        });
        $('#listaPasillos').html(html || '<div class="text-muted">Todavía no hay pasillos.</div>');

        $('.wms-pasillo-item').click(function () {
            var id = $(this).data('id');
            var pasillo = pasillos.find(function (x) { return x.id === id; });
            seleccionarPasillo(pasillo);
        });
    }

    function seleccionarPasillo(p) {
        pasilloSeleccionado = p;
        $('#pasilloID').val(p.dbId);
        $('#pasilloCodigo').val(p.codigo);
        $('#pasilloNombre').val(p.nombre);
        $('#pasilloX').val(p.x);
        $('#pasilloY').val(p.y);
        $('#pasilloLargo').val(p.largo);
        $('#pasilloAncho').val(p.ancho);
        $('#pasilloOrientacion').val(p.orientacion || 'H');
        $('#pasilloPosiciones').val(p.posiciones);
        $('#pasilloAlturas').val(p.alturas);
        $('#pasilloAlturaNivel').val(p.alturaNivel);
        $('#pasilloPesoMaximo').val(p.pesoMaximo);
        $('#pasilloZona').val(p.zonaDbId || 0);
        zonaSeleccionada = zonas.find(function (z) { return String(z.dbId) === String(p.zonaDbId || 0); }) || null;
        $('.wms-pasillo-item').removeClass('active');
        $('.wms-pasillo-item[data-id="' + p.id + '"]').addClass('active');
        dibujar();
    }

    function limpiarFormulario() {
        pasilloSeleccionado = null;
        $('#pasilloID').val('0');
        $('#pasilloCodigo').val('');
        $('#pasilloNombre').val('');
        $('#pasilloX').val('40');
        $('#pasilloY').val('40');
        $('#pasilloLargo').val('240');
        $('#pasilloAncho').val('60');
        $('#pasilloOrientacion').val('H');
        $('#pasilloPosiciones').val('10');
        $('#pasilloAlturas').val('3');
        $('#pasilloAlturaNivel').val('100');
        $('#pasilloPesoMaximo').val('0');
        if (zonaSeleccionada) $('#pasilloZona').val(zonaSeleccionada.dbId);
        $('.wms-pasillo-item').removeClass('active');
        dibujar();
    }

    function actualizarPreview() {
        dibujar();
    }

        function obtenerPuntoCanvas(e) {
            var evento = e.originalEvent || e;
            var touch = evento.touches && evento.touches.length ? evento.touches[0] : (evento.changedTouches && evento.changedTouches.length ? evento.changedTouches[0] : evento);
            var rect = canvas.getBoundingClientRect();
            return {
                x: Math.round(touch.clientX - rect.left),
                y: Math.round(touch.clientY - rect.top)
            };
        }

        function obtenerMedidasPasillo(p) {
            var largo = Number(p.largo || 1);
            var ancho = Number(p.ancho || 1);
            return {
                w: p.orientacion === 'V' ? ancho : largo,
                h: p.orientacion === 'V' ? largo : ancho
            };
        }

        function posicionarFormularioEnCanvas(x, y) {
            var preview = leerFormularioComoPasillo();
            var medidas = obtenerMedidasPasillo(preview);
            $('#pasilloX').val(Math.max(0, Math.min(x, canvas.width - medidas.w)));
            $('#pasilloY').val(Math.max(0, Math.min(y, canvas.height - medidas.h)));
        }

        function iniciarArrastrePasillo(e) {
            var punto = obtenerPuntoCanvas(e);
            var encontrado = buscarPasilloEnPunto(punto.x, punto.y);
            dragMovido = false;
            dragActivo = true;

            if (encontrado) {
                seleccionarPasillo(encontrado);
                dragPasillo = encontrado;
            } else if ($('#pasilloCodigo').val()) {
                dragPasillo = leerFormularioComoPasillo();
                posicionarFormularioEnCanvas(punto.x, punto.y);
            } else {
                dragActivo = false;
                dragPasillo = null;
                return;
            }

            dragOffsetX = punto.x - Number($('#pasilloX').val() || 0);
            dragOffsetY = punto.y - Number($('#pasilloY').val() || 0);
            $('#canvasPasillos').addClass('dragging');
            e.preventDefault();
        }

        function moverPasilloArrastrado(e) {
            if (!dragActivo || !dragPasillo) return;

            var punto = obtenerPuntoCanvas(e);
            var preview = leerFormularioComoPasillo();
            var medidas = obtenerMedidasPasillo(preview);
            var nuevoX = Math.max(0, Math.min(punto.x - dragOffsetX, canvas.width - medidas.w));
            var nuevoY = Math.max(0, Math.min(punto.y - dragOffsetY, canvas.height - medidas.h));

            if (Math.abs(Number($('#pasilloX').val() || 0) - nuevoX) > 1 || Math.abs(Number($('#pasilloY').val() || 0) - nuevoY) > 1) {
                dragMovido = true;
            }

            $('#pasilloX').val(Math.round(nuevoX));
            $('#pasilloY').val(Math.round(nuevoY));
            dibujar();
            e.preventDefault();
        }

        function finalizarArrastrePasillo() {
            if (!dragActivo) return;
            dragActivo = false;
            dragPasillo = null;
            $('#canvasPasillos').removeClass('dragging');
        }

    function dibujar() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        zonas.forEach(dibujarZona);
        pasillos.forEach(function (p) {
            var estaSeleccionado = pasilloSeleccionado && p.id === pasilloSeleccionado.id;
            dibujarPasillo(estaSeleccionado ? leerFormularioComoPasillo() : p, estaSeleccionado);
        });

        if (!pasilloSeleccionado && $('#pasilloCodigo').val()) {
            dibujarPasillo(leerFormularioComoPasillo(), true, true);
        }
    }

    function dibujarZona(z) {
        var x = Number(z.x || 0), y = Number(z.y || 0), w = Number(z.largo || 520), h = Number(z.ancho || 260);
        ctx.fillStyle = zonaSeleccionada && String(zonaSeleccionada.dbId) === String(z.dbId) ? 'rgba(59,130,246,0.12)' : 'rgba(148,163,184,0.10)';
        ctx.strokeStyle = zonaSeleccionada && String(zonaSeleccionada.dbId) === String(z.dbId) ? '#2563eb' : '#94a3b8';
        ctx.setLineDash([8, 6]); ctx.lineWidth = 2; ctx.fillRect(x, y, w, h); ctx.strokeRect(x, y, w, h); ctx.setLineDash([]);
        ctx.fillStyle = '#334155'; ctx.font = 'bold 13px Arial'; ctx.fillText((z.codigo || 'Z') + ' - ' + (z.nombre || 'Zona'), x + 10, y + 20);
    }

    function dibujarPasillo(p, seleccionado, preview) {
        var x = Number(p.x || 0);
        var y = Number(p.y || 0);
        var medidas = obtenerMedidasPasillo(p);
        var w = medidas.w;
        var h = medidas.h;
        var posiciones = Number(p.posiciones || 1);

        ctx.fillStyle = preview ? 'rgba(16,185,129,0.25)' : (seleccionado ? '#34d399' : '#93c5fd');
        ctx.strokeStyle = seleccionado ? '#047857' : '#2563eb';
        ctx.lineWidth = seleccionado ? 3 : 1;
        ctx.fillRect(x, y, w, h);
        ctx.strokeRect(x, y, w, h);

        ctx.strokeStyle = 'rgba(15,23,42,0.35)';
        for (var i = 1; i < posiciones; i++) {
            if (p.orientacion === 'V') {
                var py = y + (h / posiciones) * i;
                ctx.beginPath(); ctx.moveTo(x, py); ctx.lineTo(x + w, py); ctx.stroke();
            } else {
                var px = x + (w / posiciones) * i;
                ctx.beginPath(); ctx.moveTo(px, y); ctx.lineTo(px, y + h); ctx.stroke();
            }
        }

        ctx.fillStyle = '#0f172a';
        ctx.font = '12px Arial';
        ctx.fillText((p.codigo || '') + ' (' + posiciones + 'x' + (p.alturas || 1) + ')', x + 6, y + 18);
    }

    function buscarPasilloEnPunto(x, y) {
        for (var i = pasillos.length - 1; i >= 0; i--) {
            var p = pasillos[i];
            var medidas = obtenerMedidasPasillo(p);
            var w = medidas.w;
            var h = medidas.h;
            if (x >= Number(p.x) && x <= Number(p.x) + w && y >= Number(p.y) && y <= Number(p.y) + h) return p;
        }
        return null;
    }

    function leerFormularioComoPasillo() {
        return {
            id: '0',
            codigo: $('#pasilloCodigo').val(),
            nombre: $('#pasilloNombre').val(),
            x: $('#pasilloX').val(),
            y: $('#pasilloY').val(),
            largo: $('#pasilloLargo').val(),
            ancho: $('#pasilloAncho').val(),
            orientacion: $('#pasilloOrientacion').val(),
            posiciones: $('#pasilloPosiciones').val(),
            alturas: $('#pasilloAlturas').val(),
            zonaDbId: $('#pasilloZona').val() || 0
        };
    }
    </script>
}