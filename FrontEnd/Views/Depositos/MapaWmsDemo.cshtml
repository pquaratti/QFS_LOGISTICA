                                fecha: '2026-06-' + pad((indice % 20) + 1) + ' 09:' + pad((indice * 2) % 60),
                                usuario: 'Supervisor'
                            },
                            {
                                tipo: 'Ingreso',
                                detalle: '+' + cantidad + ' un. recibidas',
