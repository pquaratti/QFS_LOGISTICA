@model Entidades.Deposito

@{
    ViewBag.Title = "Demo WMS 3D/2D";
    ViewBag.Subtitle = "Mapa interactivo de depósito";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string _ControllerName = "Depositos";
    var _pasillosWms = ViewBag.WmsPasillos ?? new object[0];
    var _zonasWms = ViewBag.WmsZonas ?? new object[0];
}

<style>
    .wms-page {
        --bg: #f3f4f6;
        --panel: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --line: #e2e8f0;
        --blue: #0d6efd;
        --dark3d: #0f172a;
    }

    * {
        box-sizing: border-box;
    }

    .wms-page {
        margin: 0;
        padding: 18px;
        font-family: Arial, Helvetica, sans-serif;
        background: var(--bg);
        color: var(--text);
    }

    .content-header {
        margin-bottom: 14px;
    }

    .content-title {
        margin: 0 0 6px 0;
        font-size: 23px;
        font-weight: 900;
        letter-spacing: -0.02em;
    }

    .content-header p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
    }

    .wms-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 14px;
        align-items: stretch;
    }

    .wms-card {
        background: var(--panel);
        border: 1px solid #e6e9ef;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .06);
        overflow: hidden;
    }

    .wms-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        padding: 12px;
        border-bottom: 1px solid #edf0f5;
        background: linear-gradient(135deg, #f8fafc, #eef6ff);
    }

    .form-control {
        width: 210px;
        max-width: 100%;
        height: 34px;
        font-size: 12px;
        padding: 0 10px;
        border: 1px solid #cbd5e1;
        border-radius: 7px;
        outline: none;
        background: white;
        color: #0f172a;
    }

        .form-control:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .btn {
        min-height: 34px;
        padding: 0 12px;
        border-radius: 7px;
        border: 1px solid var(--blue);
        background: transparent;
        color: var(--blue);
        cursor: pointer;
        font-weight: 700;
        font-size: 12px;
    }

        .btn:hover {
            background: var(--blue);
            color: white;
        }

    .btn-solid {
        background: var(--blue);
        color: #fff;
    }

    .btn-soft {
        border-color: #cbd5e1;
        color: #334155;
        background: #f8fafc;
    }

        .btn-soft:hover {
            background: #e2e8f0;
            color: #0f172a;
            border-color: #cbd5e1;
        }

    .wms-tabs {
        display: inline-flex;
        border-radius: 999px;
        padding: 3px;
        background: #e9eef7;
    }

    .wms-tab {
        border: 0;
        border-radius: 999px;
        padding: 7px 14px;
        background: transparent;
        color: #516070;
        font-weight: 800;
        cursor: pointer;
        font-size: 12px;
    }

        .wms-tab.active {
            background: var(--blue);
            color: #fff;
            box-shadow: 0 4px 10px rgba(13,110,253,.28);
        }

    .wms-viewport {
        position: relative;
        height: 670px;
        width: 100%;
        background: var(--dark3d);
    }

    #wms3d,
    #wms2d {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    #wms2d {
        display: none;
        background: #f8fafc;
        overflow: auto;
        padding: 22px;
    }

    .wms-help {
        position: absolute;
        left: 12px;
        bottom: 12px;
        z-index: 5;
        color: #cbd5e1;
        background: rgba(15,23,42,.82);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 10px;
        padding: 9px 12px;
        font-size: 12px;
        pointer-events: none;
    }

    .wms-tooltip {
        display: none;
        position: absolute;
        z-index: 8;
        pointer-events: none;
        background: rgba(15, 23, 42, .94);
        color: white;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 10px;
        padding: 9px 10px;
        font-size: 12px;
        box-shadow: 0 12px 30px rgba(0,0,0,.25);
        max-width: 260px;
    }

        .wms-tooltip strong {
            display: block;
            margin-bottom: 3px;
        }

        .wms-tooltip span {
            color: #cbd5e1;
        }

    .wms-map2d {
        position: relative;
        width: 1060px;
        height: 640px;
        margin: 0 auto;
        border: 2px solid #1f2937;
        border-radius: 14px;
        background: linear-gradient(90deg, rgba(59, 130, 246, .08) 0 21%, transparent 21% 26%, rgba(59, 130, 246, .08) 26% 47%, transparent 47% 53%, rgba(59, 130, 246, .08) 53% 74%, transparent 74% 100%), repeating-linear-gradient(0deg, #f8fafc 0, #f8fafc 23px, #edf2f7 24px), repeating-linear-gradient(90deg, transparent 0, transparent 23px, rgba(148,163,184,.35) 24px);
        overflow: hidden;
    }

    .wms-zone-title {
        position: absolute;
        top: 16px;
        height: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #334155;
        background: rgba(255,255,255,.7);
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .04em;
    }

    .wms-bin2d {
        position: absolute;
        border: 1px solid rgba(15,23,42,.28);
        border-radius: 6px;
        cursor: pointer;
        color: #0f172a;
        font-size: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        transition: transform .15s, box-shadow .15s, outline .15s;
        user-select: none;
        z-index: 2;
    }

        .wms-bin2d:hover,
        .wms-bin2d.selected {
            transform: scale(1.12);
            box-shadow: 0 8px 18px rgba(15,23,42,.22);
            z-index: 6;
            outline: 3px solid #2563eb;
        }

        .wms-bin2d.search-match {
            outline: 3px solid #a855f7;
            box-shadow: 0 0 18px rgba(168, 85, 247, .65);
            z-index: 5;
        }

        .wms-bin2d.picking-target {
            outline: 3px solid #fb923c;
            box-shadow: 0 0 22px rgba(251, 146, 60, .75);
            z-index: 7;
        }

        .wms-bin2d.putaway-target {
            outline: 3px solid #06b6d4;
            box-shadow: 0 0 22px rgba(6, 182, 212, .75);
            z-index: 7;
        }

    .wms-rack-label {
        position: absolute;
        color: #475569;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: .05em;
        transform: rotate(-90deg);
        transform-origin: left top;
    }


    .wms-rack-label-horizontal {
        transform: none;
        width: 84px;
        text-align: center;
        padding: 3px 8px;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        background: rgba(255,255,255,.86);
    }

    .wms-aisle {
        position: absolute;
        border: 2px solid rgba(37, 99, 235, .45);
        border-radius: 8px;
        background: rgba(147, 197, 253, .16);
        z-index: 1;
    }

    .wms-dock {
        position: absolute;
        left: 28px;
        bottom: 24px;
        right: 28px;
        height: 76px;
        border: 2px dashed #64748b;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #475569;
        font-weight: 900;
        background: rgba(226,232,240,.72);
    }

    .wms-gate {
        position: absolute;
        bottom: 0;
        width: 92px;
        height: 18px;
        background: #334155;
        color: white;
        border-radius: 8px 8px 0 0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 10px;
        font-weight: 800;
    }

    .wms-side {
        padding: 14px;
        overflow: auto;
        max-height: 730px;
    }

    .wms-kpis {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px;
    }

    .wms-kpi {
        border-radius: 12px;
        padding: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .wms-kpi strong {
            display: block;
            font-size: 22px;
            color: #0f172a;
            line-height: 1;
            margin-bottom: 5px;
        }

        .wms-kpi span {
            color: #64748b;
            font-size: 10px;
            text-transform: uppercase;
            font-weight: 900;
        }

    .wms-section-title {
        margin: 14px 0 8px;
        font-size: 12px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: .08em;
        font-weight: 900;
    }

    .wms-detail h5 {
        font-weight: 900;
        margin: 4px 0 5px 0;
        font-size: 14px;
        word-break: break-word;
    }

    .wms-badge {
        display: inline-block;
        border-radius: 999px;
        padding: 5px 10px;
        color: #0f172a;
        font-size: 11px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .wms-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 7px 0;
        border-bottom: 1px solid #edf2f7;
        font-size: 12px;
    }

        .wms-row b {
            color: #334155;
            min-width: 110px;
        }

        .wms-row span {
            text-align: right;
            color: #0f172a;
        }

    .wms-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin: 10px 0 12px;
    }

        .wms-actions .btn {
            width: 100%;
        }

    .wms-operacion-card {
        border: 1px solid #fed7aa;
        background: #fff7ed;
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 12px;
    }

        .wms-operacion-card h5 {
            margin: 0 0 8px 0;
            font-size: 13px;
            color: #9a3412;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

    .wms-operacion-pill {
        display: inline-block;
        border-radius: 999px;
        padding: 4px 9px;
        font-size: 11px;
        font-weight: 900;
        background: #fb923c;
        color: #111827;
        margin-bottom: 8px;
    }

    .wms-operacion-card .wms-row {
        border-color: rgba(251, 146, 60, .28);
    }

    .wms-operacion-card.putaway {
        border-color: #67e8f9;
        background: #ecfeff;
    }

        .wms-operacion-card.putaway h5 {
            color: #0e7490;
        }

        .wms-operacion-card.putaway .wms-operacion-pill {
            background: #06b6d4;
            color: #ffffff;
        }

        .wms-operacion-card.putaway .wms-row {
            border-color: rgba(6, 182, 212, .28);
        }

    .wms-operacion-empty {
        border: 1px dashed #cbd5e1;
        background: #f8fafc;
        color: #64748b;
        border-radius: 12px;
        padding: 10px;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .wms-legend {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 12px;
        font-size: 12px;
    }

    .wms-dot {
        width: 12px;
        height: 12px;
        display: inline-block;
        border-radius: 3px;
        margin-right: 6px;
        vertical-align: -2px;
    }

    .wms-movements {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
    }

    .wms-movement {
        padding: 9px 10px;
        border-bottom: 1px solid #edf2f7;
        font-size: 12px;
    }

        .wms-movement:last-child {
            border-bottom: 0;
        }

        .wms-movement strong {
            display: block;
            margin-bottom: 2px;
            color: #0f172a;
        }

        .wms-movement span {
            color: #64748b;
        }

    .wms-empty {
        color: #64748b;
        font-size: 12px;
        padding: 10px;
        border: 1px dashed #cbd5e1;
        border-radius: 10px;
        background: #f8fafc;
    }


    .wms-supervisor-hud {
        display: none;
        position: absolute;
        top: 14px;
        left: 14px;
        z-index: 7;
        width: 260px;
        padding: 12px;
        border-radius: 14px;
        background: rgba(15, 23, 42, .86);
        border: 1px solid rgba(255,255,255,.12);
        color: #e2e8f0;
        box-shadow: 0 12px 30px rgba(0,0,0,.26);
        pointer-events: none;
    }

        .wms-supervisor-hud.active {
            display: block;
        }

        .wms-supervisor-hud h6 {
            margin: 0 0 8px 0;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #93c5fd;
            font-weight: 900;
        }

    .wms-supervisor-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 7px;
        margin-bottom: 10px;
    }

    .wms-supervisor-item {
        padding: 8px;
        border-radius: 10px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
    }

        .wms-supervisor-item strong {
            display: block;
            color: #ffffff;
            font-size: 15px;
            line-height: 1;
            margin-bottom: 4px;
        }

        .wms-supervisor-item span {
            display: block;
            color: #cbd5e1;
            font-size: 10px;
            text-transform: uppercase;
            font-weight: 800;
        }

    .wms-minimap {
        position: relative;
        height: 118px;
        border-radius: 10px;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(59, 130, 246, .16) 0 21%, transparent 21% 26%, rgba(59, 130, 246, .16) 26% 47%, transparent 47% 53%, rgba(59, 130, 246, .16) 53% 74%, transparent 74% 100%), rgba(15, 23, 42, .72);
        border: 1px solid rgba(255,255,255,.12);
    }

    .wms-minimap-rack {
        position: absolute;
        width: 10px;
        height: 70px;
        top: 16px;
        border-radius: 3px;
        background: rgba(148, 163, 184, .8);
    }

    .wms-minimap-player {
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: #ffff00;
        border: 2px solid #0f172a;
        box-shadow: 0 0 14px rgba(255,255,0,.9);
        transform: translate(-50%, -50%);
    }

    .wms-supervisor-note {
        margin-top: 8px;
        color: #cbd5e1;
        font-size: 11px;
        line-height: 1.35;
    }

    .wms-pointer-lock-note {
        display: none;
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 9;
        padding: 10px 12px;
        border-radius: 12px;
        background: rgba(15, 23, 42, .9);
        border: 1px solid rgba(255,255,255,.14);
        color: #e2e8f0;
        font-size: 12px;
        font-weight: 800;
        pointer-events: none;
    }

        .wms-pointer-lock-note.active {
            display: block;
        }

    .wms-crosshair {
        display: none;
        position: absolute;
        left: 50%;
        top: 50%;
        z-index: 10;
        width: 16px;
        height: 16px;
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

        .wms-crosshair.active {
            display: block;
        }

        .wms-crosshair::before,
        .wms-crosshair::after {
            content: "";
            position: absolute;
            left: 50%;
            top: 50%;
            background: rgba(255, 255, 255, .92);
            box-shadow: 0 0 8px rgba(0,0,0,.75);
            transform: translate(-50%, -50%);
        }

        .wms-crosshair::before {
            width: 16px;
            height: 2px;
        }

        .wms-crosshair::after {
            width: 2px;
            height: 16px;
        }

    .wms-crosshair-dot {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 5px;
        height: 5px;
        border-radius: 999px;
        background: #ffff00;
        border: 1px solid #0f172a;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 10px rgba(255,255,0,.9);
    }

    .wms-aim-label {
        display: none;
        position: absolute;
        left: 50%;
        top: calc(50% + 22px);
        z-index: 10;
        min-width: 170px;
        max-width: 260px;
        padding: 7px 10px;
        border-radius: 10px;
        background: rgba(15, 23, 42, .9);
        color: #fff;
        border: 1px solid rgba(255,255,255,.16);
        box-shadow: 0 12px 26px rgba(0,0,0,.32);
        transform: translateX(-50%);
        pointer-events: none;
        text-align: center;
        font-size: 11px;
    }

        .wms-aim-label.active {
            display: block;
        }

        .wms-aim-label strong {
            display: block;
            font-size: 12px;
            margin-bottom: 2px;
            color: #ffff00;
        }

        .wms-aim-label span {
            color: #cbd5e1;
        }

    @@media(max-width: 1100px) {
        .wms-shell {
            grid-template-columns: 1fr;
        }

        .wms-side {
            max-height: none;
        }

        .wms-viewport {
            height: 560px;
        }
    }
</style>

<div class="wms-page">

    <div class="content-header">
        <h4 class="content-title">Demo WMS: depósito 3D + vista aérea 2D</h4>
        <p>Prototipo interactivo para visualizar racks, ubicaciones, stock, ocupación, movimientos y acciones operativas.</p>
    </div>

    <div class="wms-shell">
        <div class="wms-card">
            <div class="wms-toolbar">
                <div class="wms-tabs">
                    <button id="btnVista3d" type="button" class="wms-tab active">Vista 3D</button>
                    <button id="btnVista2d" type="button" class="wms-tab">Vista aérea 2D</button>
                    <button id="btnVistaSupervisor" type="button" class="wms-tab">Visión supervisor</button>
                </div>

                <select id="filtroZona" class="form-control"></select>

                <select id="filtroEstado" class="form-control">
                    <option value="Todos">Todos los estados</option>
                    <option value="Libre">Libre</option>
                    <option value="Ocupada">Ocupada</option>
                    <option value="Parcial">Parcial</option>
                    <option value="Reservada">Reservada</option>
                    <option value="Bloqueada">Bloqueada</option>
                </select>

                <input id="buscarProducto" class="form-control" placeholder="Buscar SKU, lote, producto o ubicación" />

                <button id="btnBuscar" type="button" class="btn btn-solid">Buscar</button>
                <button id="btnSiguienteResultado" type="button" class="btn btn-soft">Siguiente resultado (0)</button>
                <button id="btnResetCamara" type="button" class="btn">Reset cámara</button>
                <button id="btnGenerarPicking" type="button" class="btn btn-soft">Generar pedido demo</button>
                <button id="btnGenerarRecepcion" type="button" class="btn btn-soft">Generar recepción demo</button>
                <button id="btnSimularIngreso" type="button" class="btn btn-soft">Simular ingreso</button>
            </div>

            <div class="wms-viewport">
                <div id="wms3d">
                    <div id="ayuda3d" class="wms-help">3D: WASD para moverte, click derecho para rotar, rueda para zoom, click selecciona una ubicación. Doble click enfoca la selección.</div>
                    <div id="tooltip3d" class="wms-tooltip"></div>
                    <div id="pointerLockNote" class="wms-pointer-lock-note">Mouse capturado · ESC para salir</div>
                    <div id="crosshairSupervisor" class="wms-crosshair"><span class="wms-crosshair-dot"></span></div>
                    <div id="aimLabelSupervisor" class="wms-aim-label"></div>

                    <div id="supervisorHud" class="wms-supervisor-hud">
                        <h6>Visión supervisor</h6>

                        <div class="wms-supervisor-grid">
                            <div class="wms-supervisor-item">
                                <strong id="supPasillo">-</strong>
                                <span>Pasillo cercano</span>
                            </div>
                            <div class="wms-supervisor-item">
                                <strong id="supSector">Zona A</strong>
                                <span>Sector</span>
                            </div>
                            <div class="wms-supervisor-item">
                                <strong id="supVisibles">0</strong>
                                <span>Cajas visibles</span>
                            </div>
                            <div class="wms-supervisor-item">
                                <strong id="supModo">Walk</strong>
                                <span>Modo cámara</span>
                            </div>
                        </div>

                        <div class="wms-minimap">
                            <div class="wms-minimap-rack" style="left: 44px;"></div>
                            <div class="wms-minimap-rack" style="left: 60px;"></div>
                            <div class="wms-minimap-rack" style="left: 104px;"></div>
                            <div class="wms-minimap-rack" style="left: 120px;"></div>
                            <div class="wms-minimap-rack" style="left: 164px;"></div>
                            <div class="wms-minimap-rack" style="left: 180px;"></div>
                            <div id="miniPlayer" class="wms-minimap-player"></div>
                        </div>

                        <div class="wms-supervisor-note">
                            Apuntá con el punto central. Click selecciona la caja enfocada. WASD recorre el depósito y el mouse mira libremente. ESC libera el cursor.
                        </div>
                    </div>
                </div>

                <div id="wms2d">
                    <div id="wmsMap2d" class="wms-map2d">
                        <div class="wms-zone-title" style="left: 70px; width: 200px;">PASILLO 01</div>
                        <div class="wms-zone-title" style="left: 355px; width: 200px;">PASILLO 02</div>
                        <div class="wms-zone-title" style="left: 640px; width: 200px;">PASILLO 03</div>

                        <div class="wms-dock">Zona de recepción / despacho</div>
                        <div class="wms-gate" style="left: 150px;">Doca 01</div>
                        <div class="wms-gate" style="left: 484px;">Doca 02</div>
