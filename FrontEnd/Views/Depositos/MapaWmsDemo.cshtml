                            usuario: 'Recepción'
                        },
                        {
                            tipo: 'Reserva',
                            detalle: reservado + ' un. reservadas para pedido',
                            fecha: '2026-06-' + pad((indice % 22) + 1) + ' 11:' + pad((indice * 7) % 60),
                            usuario: 'Sistema'
                        },
                        {
                            tipo: 'Conteo',
                            detalle: 'Conteo cíclico sin diferencias',
                            fecha: '2026-06-' + pad((indice % 23) + 1) + ' 14:' + pad((indice * 9) % 60),
                            usuario: 'Inventario'
                        }
                    ];
                }

                function prepararUv2(geometry) {
                    if (geometry.attributes.uv && !geometry.attributes.uv2) {
                        geometry.setAttribute('uv2', new THREE.BufferAttribute(geometry.attributes.uv.array, 2));
                    }

                    return geometry;
                }

                function cargarTexturaRepetida(path, repeatX, repeatY, esColor) {
                    var texture = new THREE.TextureLoader().load(path);

                    if (esColor && THREE.sRGBEncoding) {
                        texture.encoding = THREE.sRGBEncoding;
                    }

                    texture.wrapS = THREE.RepeatWrapping;
                    texture.wrapT = THREE.RepeatWrapping;
                    texture.repeat.set(repeatX, repeatY);

                    if (renderer && renderer.capabilities) {
                        texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
                    }

                    return texture;
                }

                function crearMaterialPisoDeposito(repeatX, repeatY) {
