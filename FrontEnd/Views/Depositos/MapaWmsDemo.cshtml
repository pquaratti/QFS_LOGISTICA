                function iniciar3d() {
                    escena = new THREE.Scene();
                    escena.background = new THREE.Color(0x0f172a);

                    camara = new THREE.PerspectiveCamera(
                        55,
                        contenedor.clientWidth / contenedor.clientHeight,
                        .1,
                        1000
                    );

                    renderer = new THREE.WebGLRenderer({ antialias: true });
                    renderer.setSize(contenedor.clientWidth, contenedor.clientHeight);
                    renderer.setPixelRatio(window.devicePixelRatio || 1);
                    renderer.shadowMap.enabled = true;

                    contenedor.appendChild(renderer.domElement);

                    controles = new THREE.OrbitControls(camara, renderer.domElement);
                    controles.enableDamping = true;
                    controles.dampingFactor = .08;
                    controles.maxPolarAngle = Math.PI / 2.05;
                    controles.enablePan = false;

                    // Mouse:
                    // - Click izquierdo queda libre para seleccionar cajas.
                    // - Click derecho rota la cámara.
                    // - Rueda hace zoom.
                    controles.mouseButtons = {
                        LEFT: null,
                        MIDDLE: THREE.MOUSE.DOLLY,
                        RIGHT: THREE.MOUSE.ROTATE
                    };

                    raycaster = new THREE.Raycaster();
                    mouse = new THREE.Vector2();

                    resetCamara();

                    escena.add(new THREE.HemisphereLight(0xffffff, 0x334155, 1.35));

                    var luz = new THREE.DirectionalLight(0xffffff, .95);
                    luz.position.set(6, 16, 10);
                    luz.castShadow = true;
                    escena.add(luz);

                    crearDeposito3d();
                    crearRacks3d();
                    crearUbicaciones3d();
                    crearHoverOutline3d();
                    crearSelectedOutline3d();
                    crearCarteles3d();

                    contenedor.addEventListener('click', click3d, false);
                    contenedor.addEventListener('contextmenu', function (event) {
                        event.preventDefault();
                    }, false);
                    document.addEventListener('pointerlockchange', cambioPointerLockSupervisor, false);
                    document.addEventListener('mousemove', moverMouseSupervisor, false);
                    contenedor.addEventListener('dblclick', function () {
                        if (seleccionActual) enfocarUbicacion(seleccionActual);
                    }, false);
                    contenedor.addEventListener('mousemove', moverMouse3d, false);
                    contenedor.addEventListener('mouseleave', function () {
                        ocultarTooltip();
                        limpiarHover3d();
                    }, false);

                    window.addEventListener('keydown', keydownMovimiento, false);
                    window.addEventListener('keyup', keyupMovimiento, false);
                    window.addEventListener('resize', resize3d, false);
                }

                function crearDeposito3d() {
                    var materialPisoDeposito = crearMaterialPisoDeposito(6, 4);

                    var piso = new THREE.Mesh(
                        prepararUv2(new THREE.BoxGeometry(limitesDeposito3d.ancho, .08, limitesDeposito3d.profundidad)),
                        materialPisoDeposito
                    );

                    piso.position.set(limitesDeposito3d.centroX, -.08, limitesDeposito3d.centroZ);
                    piso.receiveShadow = true;
                    escena.add(piso);

                    var materialPared = new THREE.MeshStandardMaterial({
                        color: 0x1e293b,
                        transparent: true,
                        opacity: .42,
                        roughness: .9,
                        metalness: 0
                    });

                    var paredFondo = new THREE.Mesh(new THREE.BoxGeometry(limitesDeposito3d.ancho, 2.4, .12), materialPared);
                    paredFondo.position.set(limitesDeposito3d.centroX, 1.15, limitesDeposito3d.minZ - .05);;
                    escena.add(paredFondo);

                    var paredIzq = new THREE.Mesh(new THREE.BoxGeometry(.12, 2.4, limitesDeposito3d.profundidad), materialPared);
                    paredIzq.position.set(limitesDeposito3d.minX - .05, 1.15, limitesDeposito3d.centroZ);
                    escena.add(paredIzq);

                    var paredDer = new THREE.Mesh(new THREE.BoxGeometry(.12, 2.4, limitesDeposito3d.profundidad), materialPared);
                    paredDer.position.set(limitesDeposito3d.maxX + .05, 1.15, limitesDeposito3d.centroZ);
                    escena.add(paredDer);

                    var zonaDock = new THREE.Mesh(
                        prepararUv2(new THREE.BoxGeometry(Math.max(6, limitesDeposito3d.ancho - 2), .05, 1.25)),
                        crearMaterialPisoDeposito(Math.max(2, limitesDeposito3d.ancho / 4), 1)
                    );
                    zonaDock.position.set(limitesDeposito3d.centroX, .02, limitesDeposito3d.dockZ);
                    escena.add(zonaDock);
                }

                function crearRacks3d() {
                    if (layoutPasillos.length) {
                        layoutPasillos.forEach(function (pasillo) {
                            var grupo = new THREE.Group();
                            crearRackFrameDesdePasillo(grupo, pasillo);
                            grupo.userData = { pasillo: pasillo.codigo, rack: 1 };
                            escena.add(grupo);
                            rackFrames.push(grupo);
                        });
                        return;
                    }

                    for (var pasillo = 1; pasillo <= 3; pasillo++) {
                        for (var rack = 1; rack <= 2; rack++) {
                            var grupo = new THREE.Group();

                            var xBase = (pasillo - 1) * 5.6 + (rack === 1 ? -0.72 : 0.72);
                            var zCentro = -.64;

                            crearRackFrame(grupo, xBase, zCentro);

                            grupo.userData = {
                                pasillo: pasillo,
                                rack: rack
                            };

                            escena.add(grupo);
                            rackFrames.push(grupo);
                        }
                    }
                }

                function crearRackFrameDesdePasillo(grupo, pasillo) {
                    var info = pasillo.layout3d;

                    crearRackFrame(grupo, info.x, info.z, {
                        columnas: pasillo.posiciones,
                        niveles: pasillo.alturas,
                        largo: info.largo,
                        esVertical: info.esVertical
                    });
                }

                function crearRackFrame(grupo, x, z, opciones) {
                    opciones = opciones || {};
                    var matMetal = crearMaterialPalosEstanteria(1, 4);
                    var matBase = crearMaterialPlacasEstanteria(1, 4);
                    var columnas = Math.max(1, opciones.columnas || 6);
                    var niveles = Math.max(1, opciones.niveles || 3);
                    var largo = Math.max(1.28, opciones.largo || 8.95);
                    var esVertical = !!opciones.esVertical;
                    var altoRack = .62 + (niveles - 1) * 1.18 + .72;

                    for (var c = 0; c <= columnas; c++) {
                        var avance = -largo / 2 + (largo / columnas) * c;
                        var px = esVertical ? x - .6 : x + avance;
                        var pz = esVertical ? z + avance : z - .6;

                        var poste1 = new THREE.Mesh(prepararUv2(new THREE.BoxGeometry(.08, altoRack, .08)), matMetal);
                        poste1.position.set(px, altoRack / 2, pz);
                        grupo.add(poste1);

                        px = esVertical ? x + .6 : x + avance;
                        pz = esVertical ? z + avance : z + .6;

                        var poste2 = new THREE.Mesh(prepararUv2(new THREE.BoxGeometry(.08, altoRack, .08)), matMetal);
                        poste2.position.set(px, altoRack / 2, pz);
                        grupo.add(poste2);
                    }

                    for (var n = 0; n <= niveles; n++) {
                        var y = .14 + n * 1.18;
                        var geometria = esVertical
                            ? new THREE.BoxGeometry(1.95, .08, largo)
                            : new THREE.BoxGeometry(largo, .08, 1.95);
                        var larguero = new THREE.Mesh(prepararUv2(geometria), matBase);
                        larguero.position.set(x, y, z);
                        grupo.add(larguero);
                    }
                }

                function crearUbicaciones3d() {
                    ubicaciones.forEach(function (u) {
                        var material = new THREE.MeshLambertMaterial({
                            color: estadoColor[u.estado],
                            transparent: true,
                            opacity: .9
                        });

                        var mesh = new THREE.Mesh(
                            new THREE.BoxGeometry(u.ancho, u.alto, u.profundidad),
                            material
                        );

                        mesh.position.set(u.x, u.y, u.z);
                        mesh.castShadow = true;
                        mesh.receiveShadow = true;
                        mesh.userData.ubicacion = u;

                        escena.add(mesh);
                        meshes.push(mesh);

                        var borde = new THREE.EdgesGeometry(mesh.geometry);
                        var linea = new THREE.LineSegments(
                            borde,
                            new THREE.LineBasicMaterial({ color: 0x0f172a })
                        );

                        mesh.add(linea);
                    });
                }

                function crearOutlineCaja3d(color, renderOrder) {
                    // Borde solo con aristas externas.
                    // No usamos wireframe porque dibuja diagonales internas en las caras.
                    var geometria = new THREE.BoxGeometry(1.14, 1.04, 1.14);
                    var aristas = new THREE.EdgesGeometry(geometria, 1);

                    var outline = new THREE.LineSegments(
                        aristas,
                        new THREE.LineBasicMaterial({
                            color: color,
                            transparent: true,
                            opacity: 1,
                            depthTest: false
                        })
                    );

                    outline.visible = false;
                    outline.renderOrder = renderOrder;
                    escena.add(outline);

                    return outline;
                }

                function crearHoverOutline3d() {
                    hoverOutline = crearOutlineCaja3d(0xffff00, 999);
                }

                function crearSelectedOutline3d() {
                    selectedOutline = crearOutlineCaja3d(0x38bdf8, 1000);
                }

                function crearSearchOutline3d(mesh) {
                    var outline = crearOutlineCaja3d(0xa855f7, 998);
                    outline.position.copy(mesh.position);
                    outline.rotation.copy(mesh.rotation);
                    outline.scale.copy(mesh.scale);
                    outline.visible = true;
                    return outline;
                }

                function crearPickingOutline3d(mesh) {
                    var outline = crearOutlineCaja3d(colorPicking, 997);
                    outline.position.copy(mesh.position);
                    outline.rotation.copy(mesh.rotation);
                    outline.scale.copy(mesh.scale);
                    outline.visible = true;
                    return outline;
                }

                function crearRecepcionOutline3d(mesh) {
                    var outline = crearOutlineCaja3d(colorRecepcion, 996);
                    outline.position.copy(mesh.position);
                    outline.rotation.copy(mesh.rotation);
                    outline.scale.copy(mesh.scale);
                    outline.visible = true;
                    return outline;
                }

                function aplicarHover3d(mesh) {
                    if (!mesh || !hoverOutline) return;

                    meshHoverActual = mesh;

                    // Si el mouse está sobre la misma caja seleccionada, no hace falta duplicar el borde.
                    if (meshSeleccionActual && meshSeleccionActual === mesh) {
                        hoverOutline.visible = false;
                        return;
                    }

                    hoverOutline.visible = true;
                    hoverOutline.position.copy(mesh.position);
                    hoverOutline.rotation.copy(mesh.rotation);
                    hoverOutline.scale.copy(mesh.scale);
                }

                function aplicarSeleccionOutline3d(mesh) {
                    if (!mesh || !selectedOutline) return;

                    meshSeleccionActual = mesh;
                    selectedOutline.visible = true;
                    selectedOutline.position.copy(mesh.position);
                    selectedOutline.rotation.copy(mesh.rotation);
                    selectedOutline.scale.copy(mesh.scale);
                }

                function limpiarHover3d() {
                    meshHoverActual = null;

                    if (hoverOutline) {
                        hoverOutline.visible = false;
                    }
                }

                function crearCarteles3d() {
                    if (layoutPasillos.length) {
                        layoutPasillos.forEach(function (p) {
                            if (!p.layout3d) return;
                            crearTextoSprite(p.codigo, p.layout3d.x, 4.4, limitesDeposito3d.minZ + .9);
                        });
                    } else {
                        crearTextoSprite('PASILLO 01', -1.0, 4.4, -4.85);
                        crearTextoSprite('PASILLO 02', 4.65, 4.4, -4.85);
                        crearTextoSprite('PASILLO 03', 10.25, 4.4, -4.85);
                    }

                    crearTextoSprite('RECEPCIN / DESPACHO', limitesDeposito3d.centroX, .35, limitesDeposito3d.dockZ + .1);
                }

                function crearTextoSprite(texto, x, y, z) {
                    var canvas = document.createElement('canvas');
                    canvas.width = 512;
                    canvas.height = 128;

                    var ctx = canvas.getContext('2d');
                    ctx.fillStyle = 'rgba(15, 23, 42, .82)';
                    ctx.roundRect(18, 28, 476, 72, 22);
                    ctx.fill();

                    ctx.fillStyle = '#ffffff';
                    ctx.font = 'bold 34px Arial';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.fillText(texto, 256, 64);

                    var texture = new THREE.CanvasTexture(canvas);
                    var material = new THREE.SpriteMaterial({
                        map: texture,
                        transparent: true
                    });

                    var sprite = new THREE.Sprite(material);
                    sprite.position.set(x, y, z);
                    sprite.scale.set(2.8, .7, 1);
                    escena.add(sprite);
                }

                function dibujar2d() {
                    if (layoutPasillos.length) {
                        dibujar2dDesdePasillos();
                        return;
                    }

                    for (var pasillo = 1; pasillo <= 3; pasillo++) {
                        for (var rack = 1; rack <= 2; rack++) {
                            var label = document.createElement('div');
                            label.className = 'wms-rack-label';
                            label.style.left = (pasilloX2d(pasillo) + (rack === 1 ? -60 : 82)) + 'px';
                            label.style.top = '310px';
                            label.innerHTML = 'RACK 0' + rack;
                            map2d.appendChild(label);
                        }
                    }

                    ubicaciones.forEach(function (u) {
                        var div = document.createElement('div');

                        div.className = 'wms-bin2d';
                        div.dataset.id = u.id;
                        div.style.background = estadoHex[u.estado];

                        div.style.left = (pasilloX2d(u.pasillo) + (u.rack === 1 ? -25 : 32)) + 'px';
                        div.style.top = (76 + (u.columna - 1) * 69 + (u.nivel - 1) * 16) + 'px';
                        div.style.width = '44px';
                        div.style.height = '15px';

                        div.title = u.codigo;
                        div.innerHTML = 'C' + pad(u.columna) + ' N' + u.nivel;

                        div.onclick = function () {
                            seleccionar(u, false);
                        };

                        map2d.appendChild(div);
                    });
                }

                function dibujar2dDesdePasillos() {
                    var anchoMapa = map2d.clientWidth || 1100;
                    var altoMapa = map2d.clientHeight || 620;
                    var minX = Math.min.apply(null, layoutPasillos.map(function (p) { return p.x; }));
                    var minY = Math.min.apply(null, layoutPasillos.map(function (p) { return p.y; }));
                    var maxX = Math.max.apply(null, layoutPasillos.map(function (p) { return p.x + (p.orientacion === 'V' ? p.ancho : p.largo); }));
                    var maxY = Math.max.apply(null, layoutPasillos.map(function (p) { return p.y + (p.orientacion === 'V' ? p.largo : p.ancho); }));
                    var escala = Math.min((anchoMapa - 180) / Math.max(1, maxX - minX), (altoMapa - 160) / Math.max(1, maxY - minY));
                    var offsetX = (anchoMapa - (maxX - minX) * escala) / 2;
                    var offsetY = 70;

                    layoutPasillos.forEach(function (p) {
                        var esVertical = p.orientacion === 'V';
                        var left = offsetX + (p.x - minX) * escala;
                        var top = offsetY + (p.y - minY) * escala;
                        var width = (esVertical ? p.ancho : p.largo) * escala;
                        var height = (esVertical ? p.largo : p.ancho) * escala;

                        var label = document.createElement('div');
                        label.className = 'wms-rack-label wms-rack-label-horizontal';
                        label.style.left = (left + width / 2 - 42) + 'px';
                        label.style.top = Math.max(8, top - 28) + 'px';
                        label.innerHTML = p.codigo;
                        map2d.appendChild(label);

                        var fondo = document.createElement('div');
                        fondo.className = 'wms-aisle';
                        fondo.style.left = left + 'px';
                        fondo.style.top = top + 'px';
                        fondo.style.width = width + 'px';
                        fondo.style.height = height + 'px';
                        map2d.insertBefore(fondo, map2d.firstChild);
                    });

                    ubicaciones.forEach(function (u) {
                        var p = layoutPasillos.find(function (item) { return item.codigo === u.pasillo; });
                        if (!p) return;

                        var esVertical = p.orientacion === 'V';
                        var left = offsetX + (p.x - minX) * escala;
                        var top = offsetY + (p.y - minY) * escala;
                        var width = (esVertical ? p.ancho : p.largo) * escala;
                        var height = (esVertical ? p.largo : p.ancho) * escala;
                        var slot = (esVertical ? height : width) / p.posiciones;
                        var nivelOffset = (u.nivel - 1) * 16;

                        var div = document.createElement('div');
                        div.className = 'wms-bin2d';
                        div.dataset.id = u.id;
                        div.style.background = estadoHex[u.estado];
                        div.style.width = esVertical ? '44px' : Math.max(32, slot - 8) + 'px';
                        div.style.height = '15px';
                        div.style.left = (esVertical ? left + width / 2 - 22 : left + slot * (u.columna - 1) + 4) + 'px';
                        div.style.top = (esVertical ? top + slot * (u.columna - 1) + nivelOffset : top + height / 2 - 16 + nivelOffset) + 'px';
                        div.title = u.codigo;
                        div.innerHTML = 'P' + pad(u.columna) + ' N' + u.nivel;
                        div.onclick = function () { seleccionar(u, false); };
                        map2d.appendChild(div);
                    });
                }

                function pasilloX2d(pasillo) {
                    if (pasillo === 1) return 165;
                    if (pasillo === 2) return 450;
                    return 735;
                }

                function click3d(event) {
                    if (modoSupervisor && document.pointerLockElement !== renderer.domElement) {
                        renderer.domElement.requestPointerLock();
                        return;
                    }

                    var hit = modoSupervisor && document.pointerLockElement === renderer.domElement
                        ? obtenerHitCentro3d()
                        : obtenerHit3d(event);

                    if (hit) {
                        seleccionar(hit.object.userData.ubicacion, false);
                    }
                }

                function moverMouse3d(event) {
                    if (modoSupervisor && document.pointerLockElement === renderer.domElement) {
                        ocultarTooltip();
                        limpiarHover3d();
                        return;
                    }

                    var hit = obtenerHit3d(event);

                    if (!hit) {
                        ocultarTooltip();
                        limpiarHover3d();
                        return;
                    }

                    var u = hit.object.userData.ubicacion;

                    aplicarHover3d(hit.object);

                    tooltip3d.style.display = 'block';
                    tooltip3d.style.left = (event.offsetX + 14) + 'px';
                    tooltip3d.style.top = (event.offsetY + 14) + 'px';
                    tooltip3d.innerHTML =
                        '<strong>' + u.codigo + '</strong>' +
                        '<span>' + u.estado + ' · ' + u.porcentajeOcupacion + '% ocupado</span><br>' +
                        '<span>' + u.producto + '</span>';
                }

                function ocultarTooltip() {
                    tooltip3d.style.display = 'none';
                }

                function obtenerHit3d(event) {
                    var rect = renderer.domElement.getBoundingClientRect();

                    mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
                    mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

                    raycaster.setFromCamera(mouse, camara);

                    var visibles = meshes.filter(function (m) {
                        return m.visible;
                    });

                    var hits = raycaster.intersectObjects(visibles);

                    return hits.length ? hits[0] : null;
                }

                function obtenerHitCentro3d() {
                    mouse.x = 0;
                    mouse.y = 0;

                    raycaster.setFromCamera(mouse, camara);

                    var visibles = meshes.filter(function (m) {
                        return m.visible;
                    });

                    var hits = raycaster.intersectObjects(visibles);

                    return hits.length ? hits[0] : null;
                }

                function actualizarApuntadoSupervisor() {
                    if (!modoSupervisor || document.pointerLockElement !== renderer.domElement) {
                        $(aimLabelSupervisor).removeClass('active');
                        return;
                    }

                    var hit = obtenerHitCentro3d();

                    if (hit) {
                        var u = hit.object.userData.ubicacion;

                        aplicarHover3d(hit.object);

                        aimLabelSupervisor.innerHTML =
                            '<strong>' + u.codigo + '</strong>' +
                            '<span>' + u.estado + ' · ' + u.producto + '</span>';

                        $(aimLabelSupervisor).addClass('active');
                    } else {
                        limpiarHover3d();
                        $(aimLabelSupervisor).removeClass('active');
                    }
                }

                function seleccionar(u, enfocar) {
                    seleccionActual = u;

                    meshes.forEach(function (m) {
                        m.scale.set(1, 1, 1);

                        if (m.userData.ubicacion.id === u.id) {
                            m.scale.set(1.18, 1.18, 1.18);
                            aplicarSeleccionOutline3d(m);
                        }
                    });

                    $('.wms-bin2d').removeClass('selected');
                    $('.wms-bin2d[data-id="' + u.id + '"]').addClass('selected');

                    renderDetalle(u);
                    renderAcciones(u);
                    renderMovimientos(u);

                    if (enfocar) {
                        enfocarUbicacion(u);
                    }
                }

                function renderDetalle(u) {
                    $('#detalleUbicacion').html(
                        '<h5>' + u.codigo + '</h5>' +
                        '<span class="wms-badge" style="background:' + estadoHex[u.estado] + '">' +
                            u.estado + ' · ' + u.porcentajeOcupacion + '% ocupado' +
                        '</span>' +
                        fila('Producto', u.producto) +
                        fila('SKU', u.sku) +
                        fila('Cantidad física', u.cantidad + ' un.') +
                        fila('Disponible', u.disponible + ' un.') +
                        fila('Reservado', u.reservado + ' un.') +
                        fila('Lote', u.lote) +
                        fila('Vencimiento', u.vencimiento) +
                        fila('Capacidad', u.capacidadMaxima) +
                        fila('Zona', u.zona) +
                        fila('Último mov.', u.ultimoMovimiento)
                    );
                }

                function renderAcciones(u) {
                    var acciones = [];

                    if (u.estado === 'Libre') {
                        acciones = [
                            { texto: 'Asignar mercadería', tipo: 'asignar' },
                            { texto: 'Bloquear ubicación', tipo: 'bloquear' }
                        ];
                    } else if (u.estado === 'Bloqueada') {
                        acciones = [
                            { texto: 'Desbloquear', tipo: 'desbloquear' },
                            { texto: 'Ver motivo', tipo: 'motivo' }
                        ];
                    } else {
                        acciones = [
                            { texto: 'Mover stock', tipo: 'mover' },
                            { texto: 'Reservar', tipo: 'reservar' },
                            { texto: 'Enviar a picking', tipo: 'picking' },
                            { texto: 'Bloquear stock', tipo: 'bloquear' }
                        ];
                    }

                    if (pickingActivo && pickingActivo.estado === 'Pendiente' && pickingActivo.ubicacionId === u.id) {
                        acciones.unshift({ texto: 'Confirmar picking', tipo: 'confirmarPicking', importante: true });
                    }

                    if (recepcionActiva && recepcionActiva.estado === 'Pendiente de ubicar' && recepcionActiva.ubicacionId === u.id) {
                        acciones.unshift({ texto: 'Confirmar ubicación', tipo: 'confirmarPutaway', importante: true });
                    }

                    var html = acciones.map(function (a) {
                        var clase = a.importante ? 'btn btn-solid' : 'btn btn-soft';
                        return '<button type="button" class="' + clase + '" data-accion="' + a.tipo + '">' + a.texto + '</button>';
                    }).join('');

                    $('#accionesUbicacion').html(html);

                    $('#accionesUbicacion .btn').on('click', function () {
                        ejecutarAccion($(this).data('accion'));
                    });
                }

                function renderMovimientos(u) {
                    if (!u.movimientos || !u.movimientos.length) {
                        $('#movimientosUbicacion').html('<div class="wms-empty">Sin movimientos registrados.</div>');
                        return;
                    }

                    var html = u.movimientos.map(function (m) {
                        return '<div class="wms-movement">' +
                            '<strong>' + m.tipo + '</strong>' +
                            '<span>' + m.fecha + ' · ' + m.usuario + '</span><br>' +
                            '<span>' + m.detalle + '</span>' +
                        '</div>';
                    }).join('');

                    $('#movimientosUbicacion').html(html);
                }

                function ejecutarAccion(accion) {
                    if (!seleccionActual) return;

                    var u = seleccionActual;

                    if (accion === 'confirmarPicking') {
                        confirmarPicking();
                        return;
                    }

                    if (accion === 'confirmarPutaway') {
                        confirmarPutaway();
                        return;
                    }

                    if (accion === 'asignar') {
                        u.estado = 'Parcial';
                        u.producto = 'Mercadería pendiente';
                        u.sku = 'SKU-DEMO';
                        u.cantidad = 45;
                        u.disponible = 45;
                        u.reservado = 0;
                        u.porcentajeOcupacion = 45;
                        u.lote = 'LT-DEMO';
                        u.vencimiento = '2027-12-31';
                        agregarMovimiento(u, 'Put-away', '+45 un. asignadas a ubicación', 'Operario Recepción');
                    }

                    if (accion === 'bloquear') {
                        u.estado = 'Bloqueada';
                        u.porcentajeOcupacion = Math.max(100, u.porcentajeOcupacion);
                        agregarMovimiento(u, 'Bloqueo', 'Ubicación/stock bloqueado manualmente', 'Supervisor');
                    }

                    if (accion === 'desbloquear') {
                        u.estado = u.cantidad > 0 ? 'Ocupada' : 'Libre';
                        if (u.cantidad === 0) u.porcentajeOcupacion = 0;
                        agregarMovimiento(u, 'Desbloqueo', 'Ubicación desbloqueada', 'Supervisor');
                    }

                    if (accion === 'reservar') {
                        if (u.disponible > 0) {
                            var cant = Math.min(10, u.disponible);
                            u.disponible -= cant;
                            u.reservado += cant;
                            u.estado = 'Reservada';
                            agregarMovimiento(u, 'Reserva', cant + ' un. reservadas para pedido demo', 'Sistema');
                        }
                    }

                    if (accion === 'mover') {
                        agregarMovimiento(u, 'Movimiento interno', 'Se generó una tarea de traslado interno', 'Supervisor');
                    }

                    if (accion === 'picking') {
                        if (u.disponible > 0) {
                            var pick = Math.min(8, u.disponible);
                            u.disponible -= pick;
                            u.cantidad -= pick;
                            u.porcentajeOcupacion = Math.max(0, u.porcentajeOcupacion - 8);

                            if (u.cantidad <= 0) {
                                u.estado = 'Libre';
                                u.producto = 'Sin stock';
                                u.sku = '-';
                                u.lote = '-';
                                u.vencimiento = '-';
                                u.reservado = 0;
                                u.disponible = 0;
                                u.porcentajeOcupacion = 0;
                            }

                            agregarMovimiento(u, 'Picking', '-' + pick + ' un. retiradas para preparación', 'Operario Picking');
                        }
                    }

                    if (accion === 'motivo') {
                        agregarMovimiento(u, 'Consulta', 'Motivo: control de calidad / inventario pendiente', 'Auditoría');
                    }

                    refrescarVisuales();
                    actualizarKpis();
                    seleccionar(u, false);
                }

                function generarPedidoPickingDemo() {
                    recepcionActiva = null;
                    limpiarRecepcionVisual();

                    var candidatos = ubicaciones.filter(function (u) {
                        return u.estado !== 'Libre' &&
                            u.estado !== 'Bloqueada' &&
                            u.disponible > 0 &&
                            u.sku !== '-';
                    });

                    if (!candidatos.length) {
                        alert('No hay ubicaciones con stock disponible para generar picking.');
                        return;
                    }

                    var objetivo = candidatos[Math.floor(Math.random() * candidatos.length)];
                    var cantidad = Math.min(8, objetivo.disponible);

                    pickingActivo = {
                        id: 'PED-' + pad(contadorPedidoDemo++),
                        estado: 'Pendiente',
                        ubicacionId: objetivo.id,
                        codigoUbicacion: objetivo.codigo,
                        producto: objetivo.producto,
                        sku: objetivo.sku,
                        lote: objetivo.lote,
                        cantidad: cantidad
                    };

                    aplicarFiltroBusquedaDesdePicking(objetivo);
                    pintarPickingActivo();
                    renderOperacionActiva();
                    seleccionar(objetivo, true);
                }

                function aplicarFiltroBusquedaDesdePicking(u) {
                    $('#buscarProducto').val(u.sku);
                    $('#filtroEstado').val('Todos');
                    aplicarFiltros();

                    indiceResultadoActual = resultadosBusqueda.findIndex(function (x) {
                        return x.id === u.id;
                    });

                    actualizarBotonSiguienteResultado();
                }

                function pintarPickingActivo() {
                    limpiarPickingVisual();

                    if (!pickingActivo || pickingActivo.estado !== 'Pendiente') return;

                    var mesh = obtenerMeshPorUbicacion(pickingActivo.ubicacionId);

                    if (mesh) {
                        pickingOutline = crearPickingOutline3d(mesh);
                    }

                    $('.wms-bin2d[data-id="' + pickingActivo.ubicacionId + '"]').addClass('picking-target');
                }

                function limpiarPickingVisual() {
                    if (pickingOutline) {
                        escena.remove(pickingOutline);

                        if (pickingOutline.geometry) outlineSafeDispose(pickingOutline.geometry);
                        if (pickingOutline.material) outlineSafeDispose(pickingOutline.material);

                        pickingOutline = null;
                    }

                    $('.wms-bin2d').removeClass('picking-target');
                }

                function outlineSafeDispose(obj) {
                    if (obj && typeof obj.dispose === 'function') {
                        obj.dispose();
                    }
                }

                function renderOperacionActiva() {
                    if (pickingActivo) {
                        var htmlPicking =
                            '<div class="wms-operacion-card">' +
                                '<h5>Pedido de picking</h5>' +
                                '<span class="wms-operacion-pill">' + pickingActivo.estado + '</span>' +
                                fila('Pedido', pickingActivo.id) +
                                fila('Producto', pickingActivo.producto) +
                                fila('SKU', pickingActivo.sku) +
                                fila('Cantidad', pickingActivo.cantidad + ' un.') +
                                fila('Ubicación', pickingActivo.codigoUbicacion) +
                                fila('Lote', pickingActivo.lote) +
                            '</div>';

                        $('#operacionActiva').html(htmlPicking);
                        return;
                    }

                    if (recepcionActiva) {
                        var htmlRecepcion =
                            '<div class="wms-operacion-card putaway">' +
                                '<h5>Recepción / Put-away</h5>' +
                                '<span class="wms-operacion-pill">' + recepcionActiva.estado + '</span>' +
                                fila('Recepción', recepcionActiva.id) +
                                fila('Producto', recepcionActiva.producto) +
                                fila('SKU', recepcionActiva.sku) +
                                fila('Cantidad', recepcionActiva.cantidad + ' un.') +
                                fila('Ubicación sugerida', recepcionActiva.codigoUbicacion) +
                                fila('Lote', recepcionActiva.lote) +
                            '</div>';

                        $('#operacionActiva').html(htmlRecepcion);
                        return;
                    }

                    $('#operacionActiva').html('<div class="wms-operacion-empty">Sin operación activa. Generá un pedido demo o una recepción demo.</div>');
                }

                function confirmarPicking() {
                    if (!pickingActivo || pickingActivo.estado !== 'Pendiente' || !seleccionActual) return;

                    var u = seleccionActual;

                    if (u.id !== pickingActivo.ubicacionId) {
                        alert('La ubicación seleccionada no corresponde al pedido activo.');
                        return;
                    }

                    if (u.disponible < pickingActivo.cantidad) {
                        alert('La ubicación no tiene stock disponible suficiente para confirmar el picking.');
                        return;
                    }

                    u.disponible -= pickingActivo.cantidad;
                    u.cantidad -= pickingActivo.cantidad;
                    u.porcentajeOcupacion = Math.max(0, u.porcentajeOcupacion - Math.max(8, pickingActivo.cantidad));

                    if (u.cantidad <= 0) {
                        u.estado = 'Libre';
                        u.producto = 'Sin stock';
                        u.sku = '-';
                        u.lote = '-';
                        u.vencimiento = '-';
                        u.reservado = 0;
                        u.disponible = 0;
                        u.porcentajeOcupacion = 0;
                    } else if (u.disponible <= 0 && u.reservado > 0) {
                        u.estado = 'Reservada';
                    } else if (u.porcentajeOcupacion < 70) {
                        u.estado = 'Parcial';
                    } else {
                        u.estado = 'Ocupada';
                    }

                    agregarMovimiento(
                        u,
                        'Picking confirmado',
                        '-' + pickingActivo.cantidad + ' un. para ' + pickingActivo.id,
                        'Operario Picking'
                    );

                    pickingActivo.estado = 'Completado';

                    limpiarPickingVisual();
                    refrescarVisuales();
                    actualizarKpis();
                    renderOperacionActiva();
                    seleccionar(u, false);
                }

                function generarRecepcionDemo() {
                    pickingActivo = null;
                    limpiarPickingVisual();

                    var candidatos = ubicaciones.filter(function (u) {
                        return u.estado === 'Libre' || u.estado === 'Parcial';
                    });

                    if (!candidatos.length) {
                        alert('No hay ubicaciones libres o parciales para sugerir put-away.');
                        return;
                    }

                    var objetivo = candidatos.find(function (u) {
                        return u.estado === 'Libre';
                    }) || candidatos[0];

                    var productosRecepcion = [
                        { producto: 'Alcohol gel 500ml', sku: 'SKU-REC-500', cantidad: 60 },
                        { producto: 'Cinta embalaje', sku: 'SKU-REC-221', cantidad: 40 },
                        { producto: 'Etiquetas térmicas', sku: 'SKU-REC-330', cantidad: 75 },
                        { producto: 'Cajas ecommerce', sku: 'SKU-REC-118', cantidad: 35 }
                    ];

                    var item = productosRecepcion[(contadorRecepcionDemo - 1) % productosRecepcion.length];

                    recepcionActiva = {
                        id: 'REC-' + pad(contadorRecepcionDemo++),
