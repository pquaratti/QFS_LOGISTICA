                function inicializarFiltroZonas() {
                    var html = '<option value="Todas">Todas las zonas</option>';
                    (zonasDeposito || []).forEach(function (z) { html += '<option value="' + z.dbId + '">' + z.codigo + ' - ' + z.nombre + '</option>'; });
                    $('#filtroZona').html(html);
                }

                function reconstruirWmsPorZona() {
                    var origen = filtroZonaActual === 'Todas' ? pasillosDeposito : (pasillosDeposito || []).filter(function (p) { return String(p.zonaDbId || 0) === String(filtroZonaActual); });
                    layoutPasillos = normalizarPasillosDeposito(origen);
                    ubicaciones = layoutPasillos.length ? generarWmsDesdePasillos(layoutPasillos) : [];
                    limitesDeposito3d = calcularLimitesDeposito3d();
                    meshes.forEach(function (m) { escena.remove(m); });
                    meshes = [];
                    rackFrames.forEach(function (m) { escena.remove(m); });
                    rackFrames = [];
                    crearRacks3d();
                    crearUbicaciones3d();
                    crearCarteles3d();
                    dibujar2d();
                    aplicarFiltros();
                    actualizarKpis();
                    if (ubicaciones.length) seleccionar(ubicaciones[0], true);
                }

                function normalizarPasillosDeposito(pasillos) {
                    pasillos = pasillos || [];
                    return pasillos.map(function (p, index) {
                        var posiciones = Math.max(1, parseInt(p.posiciones || 1, 10));
                        var alturas = Math.max(1, parseInt(p.alturas || 1, 10));
                        var x = Number(p.x || 0);
                        var y = Number(p.y || 0);
                        var largo = Math.max(1, Number(p.largo || 240));
                        var ancho = Math.max(1, Number(p.ancho || 60));
                        var orientacion = (p.orientacion || 'H').toUpperCase();

                        return {
                            id: p.id || p.dbId || index + 1,
                            codigo: p.codigo || ('P' + pad(index + 1)),
                            nombre: p.nombre || p.codigo || ('Pasillo ' + (index + 1)),
                            x: x,
                            y: y,
                            largo: largo,
                            ancho: ancho,
                            orientacion: orientacion === 'V' ? 'V' : 'H',
                            posiciones: posiciones,
                            alturas: alturas,
                            alturaNivel: Number(p.alturaNivel || 100),
                            pesoMaximo: Number(p.pesoMaximo || 800),
                            zonaDbId: p.zonaDbId || 0,
                            zonaCodigo: p.zonaCodigo || '',
                            zonaNombre: p.zonaNombre || 'Sin zona'
                        };
                    });
                }

                function generarWmsDesdePasillos(pasillos) {
                    var productos = ['Guantes nitrilo M', 'Barbijos KN95', 'Alcohol gel 500ml', 'Cajas ecommerce', 'Repuestos crticos', 'Insumos bloqueados', 'Cinta embalaje', 'Etiquetas trmicas'];
                    var escala = .045;
                    var minX = Math.min.apply(null, pasillos.map(function (p) { return p.x; }));
                    var minY = Math.min.apply(null, pasillos.map(function (p) { return p.y; }));
                    var maxX = Math.max.apply(null, pasillos.map(function (p) { return p.x + (p.orientacion === 'V' ? p.ancho : p.largo); }));
                    var maxY = Math.max.apply(null, pasillos.map(function (p) { return p.y + (p.orientacion === 'V' ? p.largo : p.ancho); }));
                    var centroX = (minX + maxX) / 2;
                    var centroY = (minY + maxY) / 2;
                    var datos = [];
                    var id = 1;

                    pasillos.forEach(function (pasillo, indicePasillo) {
                        var esVertical = pasillo.orientacion === 'V';
                        var largo3d = pasillo.largo * escala;
                        var ancho3d = Math.max(1.2, pasillo.ancho * escala);
                        var centroPasilloX = (pasillo.x + (esVertical ? pasillo.ancho : pasillo.largo) / 2 - centroX) * escala;
                        var centroPasilloZ = (pasillo.y + (esVertical ? pasillo.largo : pasillo.ancho) / 2 - centroY) * escala;
                        var paso = largo3d / pasillo.posiciones;
                        pasillo.layout3d = { x: centroPasilloX, z: centroPasilloZ, largo: largo3d, ancho: ancho3d, esVertical: esVertical, paso: paso };

                        for (var columna = 1; columna <= pasillo.posiciones; columna++) {
                            for (var nivel = 1; nivel <= pasillo.alturas; nivel++) {
                                var indice = id + indicePasillo + columna + nivel;
                                var estado = indice % 13 === 0 ? 'Bloqueada' : indice % 7 === 0 ? 'Reservada' : indice % 5 === 0 ? 'Libre' : indice % 3 === 0 ? 'Parcial' : 'Ocupada';
                                var cantidad = estado === 'Libre' ? 0 : 18 + indice * 3;
                                var reservado = estado === 'Reservada' ? Math.floor(cantidad * .45) : indice % 8;
                                var avance = -largo3d / 2 + paso * (columna - .5);
                                var x = esVertical ? centroPasilloX : centroPasilloX + avance;
                                var z = esVertical ? centroPasilloZ + avance : centroPasilloZ;
                                var codigo = '@(Model != null && !string.IsNullOrWhiteSpace(Model.depo_codigo) ? Model.depo_codigo : "DEP")-' + pasillo.codigo + '-P' + pad(columna) + '-N' + pad(nivel);

                                datos.push({
                                    id: id++, codigo: codigo, pasillo: pasillo.codigo, pasilloNombre: pasillo.nombre, rack: 1, columna: columna, nivel: nivel,
                                    x: x, y: .62 + (nivel - 1) * 1.18, z: z,
                                    ancho: esVertical ? .92 : Math.max(.55, paso * .72), alto: .92, profundidad: esVertical ? Math.max(.55, paso * .72) : .92,
                                    estado: estado, porcentajeOcupacion: estado === 'Libre' ? 0 : (estado === 'Parcial' ? 35 + (indice % 45) : 72 + (indice % 27)),
                                    producto: estado === 'Libre' ? 'Sin stock' : productos[indice % productos.length], sku: estado === 'Libre' ? '-' : 'SKU-' + (1000 + indice),
                                    cantidad: cantidad, disponible: estado === 'Libre' ? 0 : Math.max(0, cantidad - reservado), reservado: reservado,
                                    lote: estado === 'Libre' ? '-' : 'LT-2026-' + pad(indice), vencimiento: estado === 'Libre' ? '-' : '2027-03-' + pad((indice % 27) + 1),
                                    ultimoMovimiento: '2026-06-' + pad((indice % 23) + 1) + ' 10:' + pad(indice % 60),
                                    capacidadMaxima: '1 pallet / ' + (pasillo.pesoMaximo || 800) + ' kg', zona: pasillo.zonaNombre || pasillo.nombre,
                                    movimientos: crearMovimientos(estado, codigo, cantidad, reservado, indice)
                                });
                            }
                        }
                    });

                    return datos;
                }

                function calcularLimitesDeposito3d() {
                    var padding = layoutPasillos.length ? 2.6 : 1.8;
                    var minX = Infinity;
                    var maxX = -Infinity;
                    var minZ = Infinity;
                    var maxZ = -Infinity;

                    if (layoutPasillos.length) {
                        layoutPasillos.forEach(function (p) {
                            if (!p.layout3d) return;

                            var medioLargo = p.layout3d.largo / 2;
                            var medioAncho = Math.max(1.2, p.layout3d.ancho, 1.95) / 2;

                            if (p.layout3d.esVertical) {
                                minX = Math.min(minX, p.layout3d.x - medioAncho);
                                maxX = Math.max(maxX, p.layout3d.x + medioAncho);
                                minZ = Math.min(minZ, p.layout3d.z - medioLargo);
                                maxZ = Math.max(maxZ, p.layout3d.z + medioLargo);
                            } else {
                                minX = Math.min(minX, p.layout3d.x - medioLargo);
                                maxX = Math.max(maxX, p.layout3d.x + medioLargo);
                                minZ = Math.min(minZ, p.layout3d.z - medioAncho);
                                maxZ = Math.max(maxZ, p.layout3d.z + medioAncho);
                            }
                        });
                    }

                    if (!isFinite(minX)) {
                        ubicaciones.forEach(function (u) {
                            minX = Math.min(minX, u.x - u.ancho / 2);
                            maxX = Math.max(maxX, u.x + u.ancho / 2);
                            minZ = Math.min(minZ, u.z - u.profundidad / 2);
                            maxZ = Math.max(maxZ, u.z + u.profundidad / 2);
                        });
                    }

                    if (!isFinite(minX)) {
                        minX = -5.8; maxX = 16.2; minZ = -6; maxZ = 6;
                    }

                    minX -= padding;
                    maxX += padding;
                    minZ -= padding;
                    maxZ += padding;

                    var ancho = Math.max(22, maxX - minX);
                    var profundidad = Math.max(12, maxZ - minZ);
                    var centroX = (minX + maxX) / 2;
                    var centroZ = (minZ + maxZ) / 2;

                    return {
                        minX: centroX - ancho / 2,
                        maxX: centroX + ancho / 2,
                        minZ: centroZ - profundidad / 2,
                        maxZ: centroZ + profundidad / 2,
                        ancho: ancho,
                        profundidad: profundidad,
                        centroX: centroX,
                        centroZ: centroZ,
                        dockZ: centroZ + profundidad / 2 - 1.1
                    };
                }

                function generarDemoWms() {
                    var productos = [
                        'Guantes nitrilo M',
                        'Barbijos KN95',
                        'Alcohol gel 500ml',
                        'Cajas ecommerce',
                        'Repuestos críticos',
                        'Insumos bloqueados',
                        'Cinta embalaje',
                        'Etiquetas térmicas'
                    ];

                    var datos = [];
                    var id = 1;

                    for (var pasillo = 1; pasillo <= 3; pasillo++) {
                        for (var rack = 1; rack <= 2; rack++) {
                            for (var columna = 1; columna <= 6; columna++) {
                                for (var nivel = 1; nivel <= 3; nivel++) {
                                    var indice = id + pasillo + rack + columna + nivel;

                                    var estado =
                                        indice % 13 === 0 ? 'Bloqueada' :
                                        indice % 7 === 0 ? 'Reservada' :
                                        indice % 5 === 0 ? 'Libre' :
                                        indice % 3 === 0 ? 'Parcial' :
                                        'Ocupada';

                                    var ocupacion =
                                        estado === 'Libre' ? 0 :
                                        estado === 'Parcial' ? 35 + (indice % 45) :
                                        estado === 'Bloqueada' ? 100 :
                                        72 + (indice % 27);

                                    var producto = estado === 'Libre'
                                        ? 'Sin stock'
                                        : productos[indice % productos.length];

                                    var codigo =
                                        'DEP01-ZA-P0' + pasillo +
                                        '-R0' + rack +
                                        '-C' + pad(columna) +
                                        '-N' + pad(nivel);

                                    var xBase = (pasillo - 1) * 5.6;
                                    var zBase = (columna - 1) * 1.28 - 3.84;
                                    var rackOffset = rack === 1 ? -0.72 : 0.72;

                                    var cantidad = estado === 'Libre' ? 0 : 18 + indice * 3;
                                    var reservado = estado === 'Reservada' ? Math.floor(cantidad * .45) : indice % 8;

                                    datos.push({
                                        id: id++,
                                        codigo: codigo,
                                        pasillo: pasillo,
                                        rack: rack,
                                        columna: columna,
                                        nivel: nivel,
                                        x: xBase + rackOffset,
                                        y: .62 + (nivel - 1) * 1.18,
                                        z: zBase,
                                        ancho: 1.02,
                                        alto: .92,
                                        profundidad: 1.02,
                                        estado: estado,
                                        porcentajeOcupacion: ocupacion,
                                        producto: producto,
                                        sku: estado === 'Libre' ? '-' : 'SKU-' + (1000 + indice),
                                        cantidad: cantidad,
                                        disponible: estado === 'Libre' ? 0 : Math.max(0, cantidad - reservado),
                                        reservado: reservado,
                                        lote: estado === 'Libre' ? '-' : 'LT-2026-' + pad(indice),
                                        vencimiento: estado === 'Libre' ? '-' : '2027-03-' + pad((indice % 27) + 1),
                                        ultimoMovimiento: '2026-06-' + pad((indice % 23) + 1) + ' 10:' + pad(indice % 60),
                                        capacidadMaxima: '1 pallet / 800 kg',
                                        zona: 'Zona A - Productos secos',
                                        movimientos: crearMovimientos(estado, codigo, cantidad, reservado, indice)
                                    });
                                }
                            }
                        }
                    }

                    return datos;
                }

                function crearMovimientos(estado, codigo, cantidad, reservado, indice) {
                    if (estado === 'Libre') {
                        return [
                            {
                                tipo: 'Salida completa',
                                detalle: codigo + ' quedó sin stock',
                                fecha: '2026-06-' + pad((indice % 20) + 1) + ' 16:' + pad((indice * 3) % 60),
                                usuario: 'Operario Picking'
                            }
