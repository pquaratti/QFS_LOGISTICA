                function aplicarFiltroBusquedaDesdeRecepcion(u) {
                    $('#buscarProducto').val(u.codigo);
                    $('#filtroEstado').val('Todos');
                    aplicarFiltros();

                    indiceResultadoActual = resultadosBusqueda.findIndex(function (x) {
                        return x.id === u.id;
                    });

                    actualizarBotonSiguienteResultado();
                }

                function pintarRecepcionActiva() {
                    limpiarRecepcionVisual();

                    if (!recepcionActiva || recepcionActiva.estado !== 'Pendiente de ubicar') return;

                    var mesh = obtenerMeshPorUbicacion(recepcionActiva.ubicacionId);

                    if (mesh) {
                        recepcionOutline = crearRecepcionOutline3d(mesh);
                    }

                    $('.wms-bin2d[data-id="' + recepcionActiva.ubicacionId + '"]').addClass('putaway-target');
                }

                function limpiarRecepcionVisual() {
                    if (recepcionOutline) {
                        escena.remove(recepcionOutline);

                        if (recepcionOutline.geometry) outlineSafeDispose(recepcionOutline.geometry);
                        if (recepcionOutline.material) outlineSafeDispose(recepcionOutline.material);

                        recepcionOutline = null;
                    }

                    $('.wms-bin2d').removeClass('putaway-target');
                }

                function confirmarPutaway() {
                    if (!recepcionActiva || recepcionActiva.estado !== 'Pendiente de ubicar' || !seleccionActual) return;

                    var u = seleccionActual;

                    if (u.id !== recepcionActiva.ubicacionId) {
                        alert('La ubicación seleccionada no corresponde a la recepción activa.');
                        return;
                    }

                    var estabaLibre = u.estado === 'Libre' || u.cantidad <= 0;

                    if (estabaLibre) {
                        u.producto = recepcionActiva.producto;
                        u.sku = recepcionActiva.sku;
                        u.lote = recepcionActiva.lote;
                        u.vencimiento = '2028-12-31';
                        u.cantidad = 0;
                        u.disponible = 0;
                        u.reservado = 0;
                    }

                    u.cantidad += recepcionActiva.cantidad;
                    u.disponible += recepcionActiva.cantidad;
                    u.porcentajeOcupacion = Math.min(100, Math.max(u.porcentajeOcupacion, 0) + Math.ceil(recepcionActiva.cantidad / 2));

                    if (u.porcentajeOcupacion >= 90) {
                        u.estado = 'Ocupada';
                    } else {
                        u.estado = 'Parcial';
                    }

                    agregarMovimiento(
                        u,
                        'Put-away confirmado',
                        '+' + recepcionActiva.cantidad + ' un. desde ' + recepcionActiva.id,
                        'Operario Recepción'
                    );

                    recepcionActiva.estado = 'Completado';

                    limpiarRecepcionVisual();
                    refrescarVisuales();
                    actualizarKpis();
                    renderOperacionActiva();
                    seleccionar(u, false);
                }

                function agregarMovimiento(u, tipo, detalle, usuario) {
                    var ahora = new Date();
                    var fecha =
                        ahora.getFullYear() + '-' +
                        pad(ahora.getMonth() + 1) + '-' +
                        pad(ahora.getDate()) + ' ' +
                        pad(ahora.getHours()) + ':' +
                        pad(ahora.getMinutes());

                    u.ultimoMovimiento = fecha;

                    u.movimientos.unshift({
                        tipo: tipo,
                        detalle: detalle,
                        fecha: fecha,
                        usuario: usuario
                    });

                    u.movimientos = u.movimientos.slice(0, 5);
                }

                function aplicarFiltros() {
                    var estado = $('#filtroEstado').val();
                    var texto = ($('#buscarProducto').val() || '').toLowerCase().trim();

                    limpiarResultadosBusqueda();

                    resultadosBusqueda = [];

                    meshes.forEach(function (m) {
                        var u = m.userData.ubicacion;
                        var contenido = (u.codigo + ' ' + u.producto + ' ' + u.sku + ' ' + u.lote + ' ' + u.zona).toLowerCase();

                        var cumpleEstado = estado === 'Todos' || u.estado === estado;
                        var cumpleTexto = texto === '' || contenido.indexOf(texto) >= 0;
                        var visible = cumpleEstado && cumpleTexto;

                        m.visible = visible;
                        $('.wms-bin2d[data-id="' + u.id + '"]').toggle(visible);

                        if (visible && texto !== '') {
                            resultadosBusqueda.push(u);
                        }
                    });

                    pintarResultadosBusqueda();
                    actualizarBotonSiguienteResultado();
                }

                function seleccionarPrimerResultado() {
                    aplicarFiltros();

                    if (!resultadosBusqueda.length) {
                        indiceResultadoActual = -1;
                        actualizarBotonSiguienteResultado();
                        return;
                    }

                    indiceResultadoActual = 0;
                    seleccionarResultadoActual(true);
                }

                function seleccionarSiguienteResultado() {
                    if (!resultadosBusqueda.length) return;

                    indiceResultadoActual++;

                    if (indiceResultadoActual >= resultadosBusqueda.length) {
                        indiceResultadoActual = 0;
                    }

                    seleccionarResultadoActual(true);
                }

                function seleccionarResultadoActual(enfocar) {
                    if (indiceResultadoActual < 0 || indiceResultadoActual >= resultadosBusqueda.length) return;

                    var resultado = resultadosBusqueda[indiceResultadoActual];

                    seleccionar(resultado, enfocar);
                    actualizarBotonSiguienteResultado();
                }

                function limpiarResultadosBusqueda() {
                    searchOutlines.forEach(function (outline) {
                        escena.remove(outline);

                        if (outline.geometry) outline.geometry.dispose();
                        if (outline.material) outline.material.dispose();
                    });

                    searchOutlines = [];
                    $('.wms-bin2d').removeClass('search-match');
                }

                function pintarResultadosBusqueda() {
                    resultadosBusqueda.forEach(function (u) {
                        var mesh = obtenerMeshPorUbicacion(u.id);

                        if (mesh) {
                            searchOutlines.push(crearSearchOutline3d(mesh));
                        }

                        $('.wms-bin2d[data-id="' + u.id + '"]').addClass('search-match');
                    });

                    if (!resultadosBusqueda.length) {
                        indiceResultadoActual = -1;
                    } else if (indiceResultadoActual >= resultadosBusqueda.length) {
                        indiceResultadoActual = 0;
                    }
                }

                function actualizarBotonSiguienteResultado() {
                    var total = resultadosBusqueda.length;
                    var texto = 'Siguiente resultado (' + total + ')';

                    if (total > 0 && indiceResultadoActual >= 0) {
                        texto = 'Siguiente resultado (' + (indiceResultadoActual + 1) + '/' + total + ')';
                    }

                    $('#btnSiguienteResultado').text(texto);
                }

                function obtenerMeshPorUbicacion(id) {
                    return meshes.find(function (m) {
                        return m.userData.ubicacion.id === id;
                    });
                }

                function actualizarKpis() {
                    $('#kpiUbicaciones').text(ubicaciones.length);

                    $('#kpiLibres').text(
                        ubicaciones.filter(function (u) {
                            return u.estado === 'Libre';
                        }).length
                    );

                    $('#kpiBloqueadas').text(
                        ubicaciones.filter(function (u) {
                            return u.estado === 'Bloqueada';
                        }).length
                    );

                    $('#kpiOcupacion').text(
                        Math.round(
                            ubicaciones.reduce(function (a, u) {
                                return a + u.porcentajeOcupacion;
                            }, 0) / ubicaciones.length
                        ) + '%'
                    );
                }

                function cambiarVista(vista) {
                    $('#btnVista3d,#btnVista2d,#btnVistaSupervisor').removeClass('active');

                    if (document.pointerLockElement === renderer.domElement) {
                        document.exitPointerLock();
                    }

                    if (vista === '3d') {
                        modoSupervisor = false;
                        supervisorMouseActivo = false;
                        if (controles) controles.enabled = true;
                        $('#btnVista3d').addClass('active');
                        $('#wms3d').show();
                        $('#wms2d').hide();
                        $(supervisorHud).removeClass('active');
                        $(pointerLockNote).removeClass('active');
                        $(crosshairSupervisor).removeClass('active');
                        $(aimLabelSupervisor).removeClass('active');
                        ayuda3d.innerHTML = '3D: WASD para moverte, click derecho para rotar, rueda para zoom, click selecciona una ubicación. Doble click enfoca la selección.';
                        resize3d();
                        return;
                    }

                    if (vista === 'supervisor') {
                        modoSupervisor = true;
                        if (controles) controles.enabled = false;
                        $('#btnVistaSupervisor').addClass('active');
                        $('#wms3d').show();
                        $('#wms2d').hide();
                        $(supervisorHud).addClass('active');
                        $(crosshairSupervisor).addClass('active');
                        ayuda3d.innerHTML = 'Supervisor: apuntá con el punto central. Click selecciona la caja apuntada. WASD para moverte. ESC libera el cursor.';
                        entrarModoSupervisor();
                        resize3d();
                        return;
                    }

                    modoSupervisor = false;
                    supervisorMouseActivo = false;
                    if (controles) controles.enabled = true;
                    $('#btnVista2d').addClass('active');
                    $('#wms3d').hide();
                    $('#wms2d').show();
                    $(supervisorHud).removeClass('active');
                    $(pointerLockNote).removeClass('active');
                    $(crosshairSupervisor).removeClass('active');
                    $(aimLabelSupervisor).removeClass('active');
                }

                function entrarModoSupervisor() {
                    if (!camara) return;

                    camara.position.set(limitesDeposito3d.centroX, 1.75, limitesDeposito3d.maxZ - 1.3);
                    supervisorYaw = Math.PI;
                    supervisorPitch = 0;
                    aplicarRotacionSupervisor();

                    actualizarHudSupervisor();
                }

                function cambioPointerLockSupervisor() {
                    supervisorMouseActivo = document.pointerLockElement === renderer.domElement;

                    if (supervisorMouseActivo) {
                        $(pointerLockNote).addClass('active');
                        ocultarTooltip();
                        limpiarHover3d();
                    } else {
                        $(pointerLockNote).removeClass('active');
                        $(aimLabelSupervisor).removeClass('active');
                    }
                }

                function moverMouseSupervisor(event) {
                    if (!modoSupervisor || document.pointerLockElement !== renderer.domElement) return;

                    supervisorYaw -= event.movementX * supervisorSensibilidadMouse;
                    supervisorPitch -= event.movementY * supervisorSensibilidadMouse;

                    var limiteVertical = Math.PI / 2 - 0.08;
                    supervisorPitch = Math.max(-limiteVertical, Math.min(limiteVertical, supervisorPitch));

                    aplicarRotacionSupervisor();
                }

                function aplicarRotacionSupervisor() {
                    if (!camara) return;

                    camara.rotation.order = 'YXZ';
                    camara.rotation.y = supervisorYaw;
                    camara.rotation.x = supervisorPitch;
                    camara.rotation.z = 0;
                }

                function limitarCamaraSupervisor() {
                    if (!camara) return;

                    camara.position.x = Math.max(limitesDeposito3d.minX + .8, Math.min(limitesDeposito3d.maxX - .8, camara.position.x));
                    camara.position.z = Math.max(limitesDeposito3d.minZ + .8, Math.min(limitesDeposito3d.maxZ - .8, camara.position.z));
                    camara.position.y = 1.75;
                }

                function actualizarHudSupervisor() {
                    if (!modoSupervisor || !camara) return;

                    var pasillo = obtenerPasilloCercano(camara.position.x);
                    $('#supPasillo').text(layoutPasillos.length ? pasillo : 'P0' + pasillo);
                    $('#supVisibles').text(meshes.filter(function (m) { return m.visible; }).length);

                    var mapaX = ((camara.position.x - limitesDeposito3d.minX) / limitesDeposito3d.ancho) * 230;
                    var mapaY = ((camara.position.z - limitesDeposito3d.minZ) / limitesDeposito3d.profundidad) * 108;

                    mapaX = Math.max(8, Math.min(238, mapaX));
                    mapaY = Math.max(8, Math.min(110, mapaY));

                    miniPlayer.style.left = mapaX + 'px';
                    miniPlayer.style.top = mapaY + 'px';
                }

                function obtenerPasilloCercano(x) {
                    if (layoutPasillos.length) {
                        var cercano = layoutPasillos[0];
                        var distancia = Math.abs((cercano.layout3d ? cercano.layout3d.x : 0) - x);
                        layoutPasillos.forEach(function (p) {
                            var d = Math.abs((p.layout3d ? p.layout3d.x : 0) - x);
                            if (d < distancia) { cercano = p; distancia = d; }
                        });
                        return cercano.codigo;
                    }

                    if (x < 2.3) return 1;
                    if (x < 7.9) return 2;
                    return 3;
                }

                function enfocarUbicacion(u) {
                    if (!camara) return;

                    if (modoSupervisor) {
                        camara.position.set(u.x, 1.75, u.z + 2.2);
                        var dx = u.x - camara.position.x;
                        var dz = u.z - camara.position.z;
                        supervisorYaw = Math.atan2(-dx, -dz);
                        supervisorPitch = 0;
                        aplicarRotacionSupervisor();
                        actualizarHudSupervisor();
                        return;
                    }

                    if (!controles) return;

                    controles.target.set(u.x, u.y, u.z);
                    camara.position.set(u.x + 5.2, u.y + 4.2, u.z + 5.2);
                    controles.update();
                }

                function keydownMovimiento(event) {
                    if (debeIgnorarTecla(event)) return;

                    var key = event.key.toLowerCase();

                    if (teclasMovimiento.hasOwnProperty(key)) {
                        teclasMovimiento[key] = true;
                        event.preventDefault();
                    }
                }

                function keyupMovimiento(event) {
                    var key = event.key.toLowerCase();

                    if (teclasMovimiento.hasOwnProperty(key)) {
                        teclasMovimiento[key] = false;
                        event.preventDefault();
                    }
                }

                function debeIgnorarTecla(event) {
                    var tag = event.target && event.target.tagName
                        ? event.target.tagName.toLowerCase()
                        : '';

                    return tag === 'input' || tag === 'textarea' || tag === 'select' || event.ctrlKey || event.altKey || event.metaKey;
                }

                function actualizarMovimientoCamara() {
                    if (!camara) return;

                    var movimiento = new THREE.Vector3();

                    if (modoSupervisor) {
                        var direccionSupervisor = new THREE.Vector3();
                        camara.getWorldDirection(direccionSupervisor);
                        direccionSupervisor.y = 0;
                        direccionSupervisor.normalize();

                        var derechaSupervisor = new THREE.Vector3();
                        derechaSupervisor.crossVectors(direccionSupervisor, new THREE.Vector3(0, 1, 0)).normalize();

                        if (teclasMovimiento.w) movimiento.add(direccionSupervisor);
                        if (teclasMovimiento.s) movimiento.sub(direccionSupervisor);
                        if (teclasMovimiento.a) movimiento.sub(derechaSupervisor);
                        if (teclasMovimiento.d) movimiento.add(derechaSupervisor);

                        if (movimiento.lengthSq() === 0) return;

                        movimiento.normalize().multiplyScalar(0.105);
                        camara.position.add(movimiento);

                        limitarCamaraSupervisor();
                        actualizarHudSupervisor();
                        return;
                    }

                    if (!controles) return;

                    var direccion = new THREE.Vector3();
                    camara.getWorldDirection(direccion);
                    direccion.y = 0;
                    direccion.normalize();

                    var derecha = new THREE.Vector3();
                    derecha.crossVectors(direccion, new THREE.Vector3(0, 1, 0)).normalize();

                    if (teclasMovimiento.w) movimiento.add(direccion);
                    if (teclasMovimiento.s) movimiento.sub(direccion);
                    if (teclasMovimiento.a) movimiento.sub(derecha);
                    if (teclasMovimiento.d) movimiento.add(derecha);

                    if (movimiento.lengthSq() === 0) return;

                    movimiento.normalize().multiplyScalar(velocidadMovimiento);

                    camara.position.add(movimiento);
                    controles.target.add(movimiento);
                }

                function resetCamara() {
                    if (modoSupervisor) {
                        entrarModoSupervisor();
                        return;
                    }

                    var distanciaCamara = Math.max(limitesDeposito3d.ancho, limitesDeposito3d.profundidad) * .62;
                    camara.position.set(limitesDeposito3d.centroX + distanciaCamara, 9, limitesDeposito3d.centroZ + distanciaCamara);
                    camara.lookAt(limitesDeposito3d.centroX, 1.6, limitesDeposito3d.centroZ);

                    if (controles) {
                        controles.target.set(limitesDeposito3d.centroX, 1.6, limitesDeposito3d.centroZ);
                        controles.update();
                    }
                }

                function resize3d() {
                    if (!renderer) return;

                    camara.aspect = contenedor.clientWidth / contenedor.clientHeight;
                    camara.updateProjectionMatrix();
                    renderer.setSize(contenedor.clientWidth, contenedor.clientHeight);
                }

                function animar() {
                    requestAnimationFrame(animar);

                    actualizarMovimientoCamara();

                    if (modoSupervisor) {
                        limitarCamaraSupervisor();
                        aplicarRotacionSupervisor();
                        actualizarHudSupervisor();
                        actualizarApuntadoSupervisor();
                    } else if (controles) {
                        controles.update();
                    }

                    if (renderer && escena && camara) renderer.render(escena, camara);
                }

                function refrescarVisuales() {
                    meshes.forEach(function (m) {
                        var u = m.userData.ubicacion;
                        m.material.color.setHex(estadoColor[u.estado]);
                    });

                    $('.wms-bin2d').each(function () {
                        var id = parseInt(this.dataset.id, 10);
                        var u = ubicaciones.find(function (x) { return x.id === id; });

                        if (u) {
                            this.style.background = estadoHex[u.estado];
                        }
                    });

                    aplicarFiltros();
                    pintarPickingActivo();
                    pintarRecepcionActiva();
                }

                function simularIngreso() {
                    var libre = ubicaciones.find(function (u) {
                        return u.estado === 'Libre';
                    });

                    if (!libre) {
                        alert('No hay ubicaciones libres para simular ingreso.');
                        return;
                    }

                    seleccionar(libre, true);
                    ejecutarAccion('asignar');
                }

                function fila(k, v) {
                    return '<div class="wms-row"><b>' + k + '</b><span>' + v + '</span></div>';
                }

                function pad(n) {
                    return (n < 10 ? '0' : '') + n;
                }

                if (!CanvasRenderingContext2D.prototype.roundRect) {
                    CanvasRenderingContext2D.prototype.roundRect = function (x, y, w, h, r) {
                        if (w < 2 * r) r = w / 2;
                        if (h < 2 * r) r = h / 2;
                        this.beginPath();
                        this.moveTo(x + r, y);
                        this.arcTo(x + w, y, x + w, y + h, r);
                        this.arcTo(x + w, y + h, x, y + h, r);
                        this.arcTo(x, y + h, x, y, r);
                        this.arcTo(x, y, x + w, y, r);
                        this.closePath();
                        return this;
                    };
                }
            })();
    </script>
}
